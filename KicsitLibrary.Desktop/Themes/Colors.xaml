<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Professional management palette -->
    <Color x:Key="PrimaryColor">#047857</Color> <!-- Deep Emerald -->
    <Color x:Key="SecondaryColor">#1E293B</Color> <!-- Dark Slate -->
    <Color x:Key="AccentColor">#D97706</Color> <!-- Burnished Gold -->
    <Color x:Key="AccentHoverColor">#B45309</Color>
    <Color x:Key="OperationalAccentColor">#059669</Color>
    
    <!-- Background & Neutral Colors -->
    <Color x:Key="BgColor">#F1F5F9</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#CBD5E1</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextDarkColor">#0F172A</Color>
    <Color x:Key="TextMutedColor">#475569</Color>
    <Color x:Key="TextLightColor">#FFFFFF</Color>
    
    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#059669</Color>
    <Color x:Key="DangerColor">#B91C1C</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="InfoColor">#0284C7</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="OperationalAccentBrush" Color="{StaticResource OperationalAccentColor}"/>
    
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    
    <SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDarkColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLightColor}"/>
    
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
</ResourceDictionary>
