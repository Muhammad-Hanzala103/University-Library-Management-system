<Window x:Class="KicsitLibrary.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        mc:Ignorable="d"
        Title="Login - Ilm-o-Kutub System" Height="580" MinHeight="550" Width="420" MinWidth="400"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="CanResizeWithGrip" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>
    
    <Border Background="{StaticResource BgBrush}" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="25" ShadowDepth="5" Direction="270" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/> <!-- Dark Premium Header -->
                <RowDefinition Height="*"/>    <!-- Light Form Panel -->
            </Grid.RowDefinitions>

            <!-- Header Panel with Gradient -->
            <Border Grid.Row="0" CornerRadius="15,15,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2E3E56" Offset="0.0"/>
                        <GradientStop Color="#141D2A" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16" WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Minimize button -->
                        <Button Content="—" Margin="0,0,10,0"
                                Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" 
                                FontSize="14" FontWeight="Bold" Cursor="Hand" Click="MinimizeButton_Click" ToolTip="Minimize application">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" Opacity="0.8" VerticalAlignment="Center"/>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Close button -->
                        <Button Content="✕" 
                                Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" 
                                FontSize="18" FontWeight="Bold" Cursor="Hand" Click="CloseButton_Click" ToolTip="Close application">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" Opacity="0.8"/>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Header Branding -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0">
                        <Border Width="64" Height="64" CornerRadius="32" Background="White" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="10" ShadowDepth="2"/>
                            </Border.Effect>
                            <TextBlock Text="📚" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                        </Border>
                        <TextBlock Text="Ilm-o-Kutub System" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Dr A Q Khan Institute of Computer Sciences &amp; IT" Foreground="#93C5FD" FontSize="11" Margin="0,3,0,0" HorizontalAlignment="Center" Opacity="0.9"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Form Area (Light Context) -->
            <StackPanel Grid.Row="1" Margin="35,25,35,25" VerticalAlignment="Top">
                <!-- Username -->
                <TextBlock Text="Username" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameInput" Style="{StaticResource StyledTextBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"
                         ToolTip="Enter your unique library username."/>
                
                <!-- Password -->
                <TextBlock Text="Password" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordInput" Margin="0,0,0,12" ToolTip="Enter your account password."/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" FontWeight="SemiBold" 
                           HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap" Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>

                <!-- Login Button -->
                <Button Style="{StaticResource PrimaryButton}" Content="Sign In" Height="42" FontSize="14"
                        ToolTip="Sign in with an authorized library account."
                        Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=PasswordInput}" Margin="0,0,0,10" IsDefault="True">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0F766E" Offset="0.0"/>
                            <GradientStop Color="#115E59" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- Forgot Password -->
                <Button Content="Forgot Password?" Background="Transparent" BorderThickness="0" 
                        Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="11" 
                        HorizontalAlignment="Center" Margin="0,0,0,15"
                        Click="ForgotPassword_Click" ToolTip="Reset your forgotten password.">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Create Account -->
                <Button Content="Create Account" Background="Transparent" BorderThickness="0" 
                        Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="11" 
                        HorizontalAlignment="Center" Margin="0,0,0,15"
                        Click="CreateAccount_Click" ToolTip="Request a new library account.">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="OR CONTINUE WITH" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <!-- OAuth Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Button Style="{StaticResource SecondaryButton}" Width="110" Margin="0,0,10,0"
                            Command="{Binding MicrosoftLoginCommand}" ToolTip="Sign in with Microsoft">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M 0,0 L 10,0 L 10,10 L 0,10 Z M 12,0 L 22,0 L 22,10 L 12,10 Z M 0,12 L 10,12 L 10,22 L 0,22 Z M 12,12 L 22,12 L 22,22 L 12,22 Z" Fill="#00A4EF" Margin="0,0,8,0" Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Microsoft" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Width="110"
                            Command="{Binding GoogleLoginCommand}" ToolTip="Sign in with Google">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M 11.2,4.8 C 10.6,4.2 9.8,3.9 8.9,3.9 C 7.2,3.9 5.8,5.1 5.3,6.6 C 5.2,7.1 5.1,7.5 5.1,8 C 5.1,8.5 5.2,8.9 5.3,9.4 C 5.8,10.9 7.2,12.1 8.9,12.1 C 10.4,12.1 11.6,11.3 12.2,10 L 8.9,10 L 8.9,6.9 L 15.6,6.9 C 15.7,7.4 15.7,8 15.7,8.5 C 15.7,12.8 12.8,15.8 8.9,15.8 C 4.5,15.8 0.9,12.2 0.9,7.9 C 0.9,3.6 4.5,0 8.9,0 C 11.4,0 13.5,0.9 15.2,2.5 L 12.8,4.9 C 12.4,4.5 11.9,4.2 11.2,4.8 Z" Fill="#EA4335" Margin="0,0,8,0" Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Google" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Loading State overlay -->
                <ProgressBar Height="4" IsIndeterminate="True" Background="Transparent" Foreground="{StaticResource AccentBrush}"
                             Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
