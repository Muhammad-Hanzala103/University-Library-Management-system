<Window x:Class="KicsitLibrary.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        mc:Ignorable="d"
        Title="Login - KICSIT Library" Height="500" Width="420"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Border Background="{StaticResource BgBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="20" ShadowDepth="4" Direction="270" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Close Titlebar area -->
            <Grid Grid.Row="0" Margin="15,15,15,0">
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMutedBrush}" 
                        FontSize="16" Cursor="Hand" Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Header Branding -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,15,0,10">
                <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="📚" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="KICSIT LIBRARY" Foreground="{StaticResource PrimaryBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Dr A Q Khan Institute of Computer Sciences &amp; IT" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,3,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Form Area -->
            <StackPanel Grid.Row="2" Margin="35,15,35,35" VerticalAlignment="Top">
                <!-- Username -->
                <TextBlock Text="Username" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameInput" Style="{StaticResource StyledTextBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>
                
                <!-- Password -->
                <TextBlock Text="Password" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordInput" Padding="10,8" VerticalContentAlignment="Center" FontSize="13" Height="38" Margin="0,0,0,12">
                    <PasswordBox.Template>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border Name="Border" 
                                    Background="White" 
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    BorderThickness="1.5" 
                                    CornerRadius="5">
                                <ScrollViewer x:Name="PART_ContentHost" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </PasswordBox.Template>
                </PasswordBox>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" FontWeight="SemiBold" 
                           HorizontalAlignment="Center" Margin="0,0,0,16" TextWrapping="Wrap" Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>

                <!-- Login Button -->
                <Button Style="{StaticResource PrimaryButton}" Content="Sign In" Height="40" FontSize="14"
                        Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=PasswordInput}" Margin="0,0,0,15"/>

                <!-- Loading State overlay -->
                <ProgressBar Height="4" IsIndeterminate="True" 
                             Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
