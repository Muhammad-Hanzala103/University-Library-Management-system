<Window x:Class="KicsitLibrary.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        xmlns:vm="clr-namespace:KicsitLibrary.Desktop.ViewModels"
        xmlns:views="clr-namespace:KicsitLibrary.Desktop.Views"
        mc:Ignorable="d"
        Title="Ilm-o-Kutub System" Height="768" Width="1150"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookCatalogViewModel}">
            <views:BookCatalogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentsManagementViewModel}">
            <views:StudentsManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FacultyStaffManagementViewModel}">
            <views:FacultyStaffManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VisitRecordsViewModel}">
            <views:VisitRecordsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IssueMaterialViewModel}">
            <views:IssueMaterialView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReceiveMaterialViewModel}">
            <views:ReceiveMaterialView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinesManagementViewModel}">
            <views:FinesManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OverdueRemindersViewModel}">
            <views:OverdueRemindersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotificationCenterViewModel}">
            <views:NotificationCenterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsDashboardViewModel}">
            <views:ReportsDashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClearanceDashboardViewModel}">
            <views:ClearanceDashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReservationManagementViewModel}">
            <views:ReservationManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ActivityLogsViewModel}">
            <views:ActivityLogsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditRecordsViewModel}">
            <views:AuditRecordsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InventoryManagementViewModel}">
            <views:InventoryManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockVerificationViewModel}">
            <views:StockVerificationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupManagementViewModel}">
            <views:BackupManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RestoreManagementViewModel}">
            <views:RestoreManagementView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Panel -->
        <Grid Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Product header -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="Ilm-o-Kutub" Foreground="{StaticResource TextLightBrush}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                <TextBlock Text="System" Foreground="#D1D5DB" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Navigation Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
                <StackPanel>
                    <Button Style="{StaticResource SidebarButton}" Content="Dashboard" 
                            Command="{Binding NavigateToDashboardCommand}" 
                            ToolTip="Shows overall library statistics and quick actions."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Dashboard}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Book Catalog" 
                            Command="{Binding NavigateToCatalogCommand}"
                            ToolTip="Manage titles, authors, publishers, copies, and accession numbers."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Book Catalog}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Issue Material" 
                            Command="{Binding NavigateToIssueCommand}"
                            ToolTip="Issue available books to eligible students or faculty."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Issue Material}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Receive Material" 
                            Command="{Binding NavigateToReceiveCommand}"
                            ToolTip="Receive returned books and calculate overdue fines."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Receive Material}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Fines" 
                            Command="{Binding NavigateToFinesCommand}"
                            ToolTip="Review, collect, waive, and track library fines."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Fines}"/>

                    <Button Style="{StaticResource SidebarButton}" Content="Reservations"
                            Command="{Binding NavigateToReservationsCommand}"
                            ToolTip="Manage reservation requests and title queues."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Reservations}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Overdue Reminders" 
                            Command="{Binding NavigateToOverdueCommand}"
                            ToolTip="Review overdue loans and prepare reminder records."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Overdue Reminders}"/>

                    <Button Style="{StaticResource SidebarButton}" Content="Notifications"
                            Command="{Binding NavigateToNotificationsCommand}"
                            ToolTip="Review notification history and manually deliver pending emails."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Notifications}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Students" 
                            Command="{Binding NavigateToStudentsCommand}"
                            ToolTip="Register students and maintain their library accounts."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Students}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Faculty and Staff" 
                            Command="{Binding NavigateToFacultyCommand}"
                            ToolTip="Register faculty and staff and maintain borrowing profiles."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Faculty and Staff}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Visits" 
                            Command="{Binding NavigateToVisitsCommand}"
                            ToolTip="Record accreditation, inspection, and official library visits."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Visits}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Audit Records" 
                            Command="{Binding NavigateToAuditCommand}"
                            ToolTip="Manage formal audit records, findings, and follow-up status."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Audit Records}"/>

                    <Button Style="{StaticResource SidebarButton}" Content="Activity Logs"
                            Command="{Binding NavigateToActivityLogsCommand}"
                            ToolTip="Review recorded user and system activity."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Activity Logs}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Inventory" 
                            Command="{Binding NavigateToInventoryCommand}"
                            ToolTip="Track library assets, quantities, condition, and location."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Inventory}"/>
                    <Button Style="{StaticResource SidebarButton}" Content="Stock Verification"
                            Command="{Binding NavigateToStockVerificationCommand}"
                            ToolTip="Run and reconcile physical book stock verification sessions."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Stock Verification}"/>
                    <Button Style="{StaticResource SidebarButton}" Content="Backup"
                            Command="{Binding NavigateToBackupsCommand}"
                            ToolTip="Create verified local database backups."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Backup}"/>
                    <Button Style="{StaticResource SidebarButton}" Content="Restore"
                            Command="{Binding NavigateToRestoresCommand}"
                            ToolTip="Validate and stage a safe database restore."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Restore}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Reports" 
                            Command="{Binding NavigateToReportsCommand}"
                            ToolTip="Preview and export operational library reports."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Reports}"/>

                    <Button Style="{StaticResource SidebarButton}" Content="Library Clearance"
                            Command="{Binding NavigateToClearanceCommand}"
                            ToolTip="Check dues and issue verified library clearance certificates."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Library Clearance}"/>
                    
                    <Button Style="{StaticResource SidebarButton}" Content="Settings" 
                            Command="{Binding NavigateToSettingsCommand}"
                            ToolTip="Open available application configuration options."
                            Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Settings}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- User Status Panel -->
            <Border Grid.Row="2" Background="#142038" BorderBrush="#203358" BorderThickness="0,1,0,0" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Circle Avatar placeholder -->
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                        <TextBlock Text="A" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="{Binding CurrentUserName}" Foreground="{StaticResource TextLightBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentUserRole}" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,1,0,0"/>
                    </StackPanel>
                    
                    <!-- Logout button placeholder -->
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                            Command="{Binding LogoutCommand}"
                            ToolTip="Sign out and return to the login screen.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="❌" Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header Panel -->
            <Border Grid.Row="0" Margin="15,15,15,0" Style="{StaticResource CardStyle}" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Screen Title -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextStyle}" FontSize="20"/>
                        <TextBlock Text="Dr A Q Khan Institute of Computer Sciences &amp; IT" Style="{StaticResource SubtitleTextStyle}" FontSize="11"/>
                    </StackPanel>
                    
                    <!-- Session UI preferences -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Content="Show Helpful Hints"
                                  IsChecked="{Binding ShowHelpfulHints, Mode=TwoWay}"
                                  ToolTip="Turn practical hover guidance on or off."
                                  ToolTipService.IsEnabled="{Binding ShowHelpfulHints}"
                                  Foreground="{StaticResource TextDarkBrush}"
                                  FontWeight="SemiBold"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area Viewport -->
            <Grid Grid.Row="1" Margin="15">
                <!-- If CurrentView is null, show a landing/dashboard template draft -->
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="Loading View..."/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
                
                <!-- Placeholder when view is empty (Standard Phase 1 landing look) -->
                <Grid Visibility="{Binding CurrentView, Converter={local:NullToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Quick Info Cards -->
                    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,15">
                        <!-- Card 1: Books -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Total Books" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="1,245" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="98% Available" Foreground="{StaticResource SuccessBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Issued -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Issued Books" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="142" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="12 Due Today" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Overdue -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Overdue Books" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="15" Foreground="{StaticResource DangerBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Requires Action" Foreground="{StaticResource DangerBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 4: Fines -->
                        <Border Style="{StaticResource CardStyle}" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Pending Fines" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Rs. 4,500" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="5 unpaid accounts" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Main Welcome Area -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" VerticalAlignment="Stretch">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="50">
                                <Border Width="80" Height="80" CornerRadius="40" Background="{StaticResource BgBrush}" Margin="0,0,0,15">
                                    <TextBlock Text="📚" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Ilm-o-Kutub System" Style="{StaticResource TitleTextStyle}" FontSize="22" HorizontalAlignment="Center"/>
                                <TextBlock Text="Select a module from the sidebar to manage daily library operations." 
                                           Style="{StaticResource SubtitleTextStyle}" HorizontalAlignment="Center" Margin="0,5,0,25" TextAlignment="Center"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="Quick Search Book Catalog"
                                        Command="{Binding NavigateToCatalogCommand}"
                                        ToolTip="Open the catalog to find books by title, author, or accession number."
                                        HorizontalAlignment="Center" Padding="20,10"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
