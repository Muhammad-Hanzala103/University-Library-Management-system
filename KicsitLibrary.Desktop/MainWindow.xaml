<Window x:Class="KicsitLibrary.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        xmlns:vm="clr-namespace:KicsitLibrary.Desktop.ViewModels"
        xmlns:views="clr-namespace:KicsitLibrary.Desktop.Views"
        mc:Ignorable="d"
        Title="Ilm-o-Kutub System" Height="768" Width="1150"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookCatalogViewModel}">
            <views:BookCatalogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentsManagementViewModel}">
            <views:StudentsManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FacultyStaffManagementViewModel}">
            <views:FacultyStaffManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VisitRecordsViewModel}">
            <views:VisitRecordsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IssueMaterialViewModel}">
            <views:IssueMaterialView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReceiveMaterialViewModel}">
            <views:ReceiveMaterialView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinesManagementViewModel}">
            <views:FinesManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OverdueRemindersViewModel}">
            <views:OverdueRemindersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotificationCenterViewModel}">
            <views:NotificationCenterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsDashboardViewModel}">
            <views:ReportsDashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClearanceDashboardViewModel}">
            <views:ClearanceDashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReservationManagementViewModel}">
            <views:ReservationManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ActivityLogsViewModel}">
            <views:ActivityLogsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditRecordsViewModel}">
            <views:AuditRecordsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InventoryManagementViewModel}">
            <views:InventoryManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockVerificationViewModel}">
            <views:StockVerificationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupManagementViewModel}">
            <views:BackupManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RestoreManagementViewModel}">
            <views:RestoreManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DocumentManagementViewModel}">
            <views:DocumentManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsManagementViewModel}">
            <views:SettingsManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserManagementViewModel}">
            <views:UserManagementView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="260"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                <Setter Property="Width" Value="60"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Panel -->
        <Grid Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Product header -->
            <DockPanel Grid.Row="0" Margin="10,0">
                <Button DockPanel.Dock="Left" Command="{Binding ToggleSidebarCommand}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextLightBrush}" FontSize="18" Padding="5" VerticalAlignment="Center">
                    <TextBlock Text="☰" />
                </Button>
                <StackPanel VerticalAlignment="Center" Margin="10,0" Visibility="{Binding IsSidebarExpanded, Converter={local:BooleanToVisibilityConverter}}">
                    <TextBlock Text="Ilm-o-Kutub" Foreground="{StaticResource TextLightBrush}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="System" Foreground="#D1D5DB" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>

            <!-- Navigation Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                        <Style TargetType="TextBlock" x:Key="IconStyle">
                            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
                            <Setter Property="FontSize" Value="16" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="Width" Value="40" />
                            <Setter Property="Height" Value="40" />
                            <Setter Property="Padding" Value="0,10,0,0" />
                        </Style>
                        <Style TargetType="TextBlock" x:Key="MenuHeaderStyle">
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                            <Setter Property="FontSize" Value="10" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Margin" Value="15,15,0,5" />
                            <Setter Property="Visibility" Value="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}" />
                        </Style>
                    </StackPanel.Resources>

                    <!-- Core -->
                    <TextBlock Text="CORE" Style="{StaticResource MenuHeaderStyle}" />
                    <Button Command="{Binding NavigateToDashboardCommand}" ToolTip="Dashboard" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Dashboard}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE909;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToCatalogCommand}" ToolTip="Book Catalog" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Book Catalog}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE82D;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Book Catalog" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>

                    <!-- Circulation -->
                    <TextBlock Text="CIRCULATION" Style="{StaticResource MenuHeaderStyle}" />
                    <Button Command="{Binding NavigateToIssueCommand}" ToolTip="Issue Material" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Issue Material}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Issue Material" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToReceiveCommand}" ToolTip="Receive Material" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Receive Material}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Receive Material" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToReservationsCommand}" ToolTip="Reservations" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Reservations}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Reservations" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToOverdueCommand}" ToolTip="Overdue Reminders" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Overdue Reminders}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE814;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Overdue Reminders" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToFinesCommand}" ToolTip="Fines" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Fines}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C7;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Fines" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- People -->
                    <TextBlock Text="PEOPLE" Style="{StaticResource MenuHeaderStyle}" />
                    <Button Command="{Binding NavigateToStudentsCommand}" ToolTip="Students" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Students}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Students" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToFacultyCommand}" ToolTip="Faculty and Staff" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Faculty and Staff}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Faculty and Staff" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToVisitsCommand}" ToolTip="Visits" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Visits}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE825;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Visits" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToClearanceCommand}" ToolTip="Library Clearance" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Library Clearance}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FB;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Library Clearance" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>

                    <!-- Management -->
                    <TextBlock Text="MANAGEMENT" Style="{StaticResource MenuHeaderStyle}" />
                    <Button Command="{Binding NavigateToInventoryCommand}" ToolTip="Inventory" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Inventory}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE171;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Inventory" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToStockVerificationCommand}" ToolTip="Stock Verification" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Stock Verification}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Stock Verification" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToReportsCommand}" ToolTip="Reports" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Reports}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D2;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Reports" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToNotificationsCommand}" ToolTip="Notifications" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Notifications}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEA8F;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Notifications" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>

                    <!-- System -->
                    <TextBlock Text="SYSTEM" Style="{StaticResource MenuHeaderStyle}" />
                    <Button Command="{Binding NavigateToActivityLogsCommand}" ToolTip="Activity Logs" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Activity Logs}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FD;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Activity Logs" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToAuditCommand}" ToolTip="Audit Records" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Audit Records}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Audit Records" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToDocumentsCommand}" ToolTip="Documents" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Documents}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Documents" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToBackupsCommand}" ToolTip="Backup" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Backup}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEC3E;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Backup" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToRestoresCommand}" ToolTip="Restore" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Restore}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Restore" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToSettingsCommand}" ToolTip="Settings" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter=Settings}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToAccountRequestsCommand}" ToolTip="Account Requests" Tag="{Binding Title, Converter={local:MenuSelectionConverter}, ConverterParameter='Account Requests'}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Account Requests" VerticalAlignment="Center" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={local:BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <!-- User Status Panel -->
            <Border Grid.Row="2" Background="#142038" BorderBrush="#203358" BorderThickness="0,1,0,0" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Circle Avatar placeholder -->
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                        <TextBlock Text="A" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="{Binding IsSidebarExpanded, Converter={local:BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding CurrentUserName}" Foreground="{StaticResource TextLightBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentUserRole}" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,1,0,0"/>
                    </StackPanel>
                    
                    <!-- Change Password button -->
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                            Command="{Binding ChangePasswordCommand}"
                            ToolTip="Change account password.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Logout button placeholder -->
                    <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                            Command="{Binding LogoutCommand}"
                            ToolTip="Sign out and return to the login screen.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="&#xE748;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header Panel -->
            <Border Grid.Row="0" Margin="15,15,15,0" Style="{StaticResource CardStyle}" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Screen Title -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextStyle}" FontSize="20"/>
                        <TextBlock Text="Dr A Q Khan Institute of Computer Sciences &amp; IT" Style="{StaticResource SubtitleTextStyle}" FontSize="11"/>
                    </StackPanel>
                    
                    <!-- Session UI preferences & Financial Year Selector -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Margin="0,0,15,0" Padding="0,0,15,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Financial Year:" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <RadioButton Content="Current" IsChecked="{Binding IsCurrentFinancialYear, Mode=TwoWay}" 
                                             ToolTip="Use current system financial year calculated automatically"
                                             Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <RadioButton Content="Custom" IsChecked="{Binding IsCustomFinancialYear, Mode=TwoWay}" 
                                             ToolTip="Select a custom financial year from the list"
                                             Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Width="110" Height="28" VerticalAlignment="Center" Margin="5,0,0,0"
                                          ItemsSource="{Binding AvailableFinancialYears}"
                                          SelectedValue="{Binding ActiveFinancialYear, Mode=TwoWay}"
                                          IsEnabled="{Binding IsCustomFinancialYear}"/>
                            </StackPanel>
                        </Border>

                        <CheckBox Content="Show Helpful Hints"
                                  IsChecked="{Binding ShowHelpfulHints, Mode=TwoWay}"
                                  ToolTip="Turn practical hover guidance on or off."
                                  ToolTipService.IsEnabled="{Binding ShowHelpfulHints}"
                                  Foreground="{StaticResource TextDarkBrush}"
                                  FontWeight="SemiBold"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area Viewport -->
            <Grid Grid.Row="1" Margin="15">
                <ContentControl Content="{Binding CurrentView}"/>
                
                <!-- Placeholder when view is empty (Standard Phase 1 landing look) -->
                <Grid Visibility="{Binding CurrentView, Converter={local:NullToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Quick Info Cards -->
                    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,15">
                        <!-- Card 1: Books -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Total Books" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="1,245" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="98% Available" Foreground="{StaticResource SuccessBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Issued -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Issued Books" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="142" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="12 Due Today" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Overdue -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Overdue Books" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="15" Foreground="{StaticResource DangerBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Requires Action" Foreground="{StaticResource DangerBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 4: Fines -->
                        <Border Style="{StaticResource CardStyle}" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Pending Fines" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Rs. 4,500" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="5 unpaid accounts" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Main Welcome Area -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" VerticalAlignment="Stretch">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="50">
                                <Border Width="80" Height="80" CornerRadius="40" Background="{StaticResource BgBrush}" Margin="0,0,0,15">
                                    <TextBlock Text="&#xE82D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                                </Border>
                                <TextBlock Text="Ilm-o-Kutub System" Style="{StaticResource TitleTextStyle}" FontSize="22" HorizontalAlignment="Center"/>
                                <TextBlock Text="Select a module from the sidebar to manage daily library operations." 
                                           Style="{StaticResource SubtitleTextStyle}" HorizontalAlignment="Center" Margin="0,5,0,25" TextAlignment="Center"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="Quick Search Book Catalog"
                                        Command="{Binding NavigateToCatalogCommand}"
                                        ToolTip="Open the catalog to find books by title, author, or accession number."
                                        HorizontalAlignment="Center" Padding="20,10"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
