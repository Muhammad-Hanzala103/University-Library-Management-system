<Window x:Class="KicsitLibrary.Desktop.Views.StockVerificationDetailsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Stock Verification Details" Width="520" Height="430" WindowStartupLocation="CenterOwner"><Border Style="{StaticResource CardStyle}" Margin="15"><StackPanel><TextBlock Text="{Binding Item.BookTitle}" FontSize="20" FontWeight="Bold"/><TextBlock Text="{Binding Item.AccessionNumber, StringFormat=Accession: {0}}"/><TextBlock Text="{Binding Item.Category, StringFormat=Category: {0}}"/><TextBlock Text="{Binding Item.Department, StringFormat=Department: {0}}"/><TextBlock Text="{Binding Item.Rack, StringFormat=Rack: {0}}"/><TextBlock Text="{Binding Item.Shelf, StringFormat=Shelf: {0}}"/><TextBlock Text="{Binding Item.ExpectedStatus, StringFormat=Expected status: {0}}"/><TextBlock Text="{Binding Item.ActualStatus, StringFormat=Actual status: {0}}"/><TextBlock Text="{Binding Item.IsMismatch, StringFormat=Mismatch: {0}}"/><TextBlock Text="{Binding Item.IsReconciled, StringFormat=Reconciled: {0}}"/><TextBlock Text="{Binding Item.VerificationRemarks, StringFormat=Remarks: {0}}" TextWrapping="Wrap"/></StackPanel></Border></Window>
