<UserControl x:Class="KicsitLibrary.Desktop.Views.ActivityLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Activity Log Browser" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                <WrapPanel>
                    <TextBox Width="200" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8"/>
                    <ComboBox Width="150" ItemsSource="{Binding Actions}" SelectedItem="{Binding SelectedAction}" Margin="0,0,8,8"/>
                    <ComboBox Width="140" ItemsSource="{Binding EntityNames}" SelectedItem="{Binding SelectedEntityName}" Margin="0,0,8,8"/>
                    <TextBox Width="80" Text="{Binding EntityId}" Margin="0,0,8,8"/>
                    <ComboBox Width="170" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                              DisplayMemberPath="DisplayName" Margin="0,0,8,8"/>
                    <DatePicker Width="125" SelectedDate="{Binding FromDate}" Margin="0,0,8,8"/>
                    <DatePicker Width="125" SelectedDate="{Binding ToDate}" Margin="0,0,8,8"/>
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/>
                    <Button Content="Clear" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <TextBlock Text="{Binding Summary.TotalCount, StringFormat=Total: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Summary.TodayCount, StringFormat=Today: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Summary.FailureCount, StringFormat=Failures: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Summary.DistinctUserCount, StringFormat=Users: {0}}"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Logs}" SelectedItem="{Binding SelectedLog}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date Time" Binding="{Binding CreatedAt, StringFormat={}{0:dd-MMM-yyyy HH:mm:ss}}" Width="145"/>
                    <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="130"/>
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="150"/>
                    <DataGridTextColumn Header="Entity" Binding="{Binding EntityName}" Width="105"/>
                    <DataGridTextColumn Header="ID" Binding="{Binding EntityId}" Width="55"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="75"/>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="95"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Open Details" Command="{Binding OpenDetailsCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0"/>
                    <Button Content="CSV" Command="{Binding ExportCsvCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Excel" Command="{Binding ExportExcelCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="PDF" Command="{Binding ExportPdfCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
