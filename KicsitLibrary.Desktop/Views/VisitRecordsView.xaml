<UserControl x:Class="KicsitLibrary.Desktop.Views.VisitRecordsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loader Bar -->
        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" 
                     VerticalAlignment="Top" Margin="0,0,0,10"/>

        <!-- Top Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="Accreditation &amp; Inspection Visit Records" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Log Inspection Visit" Style="{StaticResource PrimaryButton}" Command="{Binding AddVisitCommand}" Padding="15,6"/>
            </StackPanel>
        </Grid>

        <!-- Search Filters Panel -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Search Organization -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Accreditation Body / Organization Name" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding SearchOrganization, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Date of Visit -->
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Date of Visit" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <DatePicker Height="36" SelectedDate="{Binding SearchDate}"/>
                </StackPanel>

                <!-- Search Purpose -->
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Purpose of Visit" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding SearchPurpose, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Action Buttons -->
                <Grid Grid.Column="3" VerticalAlignment="Bottom" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Reset" Style="{StaticResource SecondaryButton}" Command="{Binding ClearFiltersCommand}" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Search Logs" Style="{StaticResource PrimaryButton}" Command="{Binding SearchCommand}" Margin="5,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Visit Records Data Grid -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding VisitRecords}" AutoGenerateColumns="False" IsReadOnly="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Visit Number" Binding="{Binding VisitNumber}" Width="120"/>
                    <DataGridTextColumn Header="Organization / Body" Binding="{Binding OrganizationName}" Width="1.5*"/>
                    <DataGridTextColumn Header="Date of Visit" Binding="{Binding VisitDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                    <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="2*"/>
                    <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="100"/>
                    <DataGridTextColumn Header="Logged By" Binding="{Binding CreatedByUser.FullName}" Width="110"/>
                    <DataGridTemplateColumn Width="120" Header="Actions">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✏️" ToolTip="Edit Visit Details" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.EditVisitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑️" ToolTip="Delete Record" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="12,0,0,0"
                                            Command="{Binding DataContext.DeleteVisitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Bottom Status / Errors bar -->
            <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,8,0,0"
                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
        </Grid>
    </Grid>
</UserControl>
