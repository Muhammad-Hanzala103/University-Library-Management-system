<UserControl x:Class="KicsitLibrary.Desktop.Views.BackupManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Verified Local SQLite Backups"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <WrapPanel Margin="0,10,0,0">
                    <TextBlock Text="{Binding Summary.TotalBackups, StringFormat=Total: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Summary.SuccessfulBackups, StringFormat=Successful: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Summary.FailedBackups, StringFormat=Failed: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Summary.VerifiedBackups, StringFormat=Verified: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Summary.LastBackupStatus, StringFormat=Last status: {0}}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Create Manual Backup" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Destination folder"/>
                        <TextBox Width="360" Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Reason"/>
                        <TextBox Width="260" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <CheckBox Content="Verify after creation"
                              IsChecked="{Binding VerifyAfterCreation}"
                              VerticalAlignment="Bottom"
                              Margin="0,0,10,12"/>
                    <CheckBox Content="Create ZIP"
                              IsChecked="{Binding CompressBackup}"
                              VerticalAlignment="Bottom"
                              Margin="0,0,10,12"/>
                    <Button Content="Create Backup"
                            Command="{Binding CreateBackupCommand}"
                            Style="{StaticResource PrimaryButton}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,8"/>
                </WrapPanel>
                <WrapPanel>
                    <TextBox Width="160" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,6"/>
                    <ComboBox Width="145" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Margin="0,0,6,6"/>
                    <ComboBox Width="145" ItemsSource="{Binding VerificationOptions}" SelectedItem="{Binding SelectedVerificationStatus}" Margin="0,0,6,6"/>
                    <TextBox Width="130" Text="{Binding CreatedBy}" Margin="0,0,6,6"/>
                    <DatePicker Width="125" SelectedDate="{Binding FromDate}" Margin="0,0,6,6"/>
                    <DatePicker Width="125" SelectedDate="{Binding ToDate}" Margin="0,0,6,6"/>
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/>
                    <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding BackupHistory}"
                      SelectedItem="{Binding SelectedBackup}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat={}{0:dd-MMM-yyyy HH:mm}}" Width="125"/>
                    <DataGridTextColumn Header="File Name" Binding="{Binding BackupFileName}" Width="*"/>
                    <DataGridTextColumn Header="Size (bytes)" Binding="{Binding BackupSizeBytes, StringFormat={}{0:N0}}" Width="95"/>
                    <DataGridTextColumn Header="Checksum" Binding="{Binding ChecksumSha256}" Width="160"/>
                    <DataGridTextColumn Header="Verification" Binding="{Binding VerificationStatus}" Width="90"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="115"/>
                    <DataGridTextColumn Header="Created By" Binding="{Binding CreatedBy}" Width="120"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,10,0,0">
            <StackPanel>
                <WrapPanel>
                    <Button Content="Verify Selected" Command="{Binding VerifySelectedCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/>
                    <Button Content="Open Backup Folder" Command="{Binding OpenBackupFolderCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                    <Button Content="View Details" Command="{Binding ViewDetailsCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                    <Button Content="Restore Selected" Command="{Binding RestoreSelectedCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
