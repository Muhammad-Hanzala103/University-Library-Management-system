<UserControl x:Class="KicsitLibrary.Desktop.Views.BackupManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Verified Local SQLite Backups"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <WrapPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding Summary.TotalBackups, StringFormat=Total: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding Summary.SuccessfulBackups, StringFormat=Successful: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding Summary.FailedBackups, StringFormat=Failed: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding Summary.VerifiedBackups, StringFormat=Verified: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding Summary.LastBackupStatus, StringFormat=Last status: {0}}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Create Manual Backup" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Destination folder"/>
                            <TextBox Width="360" Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Reason"/>
                            <TextBox Width="260" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <CheckBox Content="Verify after creation"
                                  IsChecked="{Binding VerifyAfterCreation}"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,10,12"/>
                        <CheckBox Content="Create ZIP"
                                  IsChecked="{Binding CompressBackup}"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,10,12"/>
                        <Button Content="Create Backup"
                                ToolTip="Create and optionally verify a new local SQLite backup."
                                Command="{Binding CreateBackupCommand}"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,8"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBox Width="160" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,6"/>
                        <ComboBox Width="145" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Margin="0,0,6,6"/>
                        <ComboBox Width="145" ItemsSource="{Binding VerificationOptions}" SelectedItem="{Binding SelectedVerificationStatus}" Margin="0,0,6,6"/>
                        <TextBox Width="130" Text="{Binding CreatedBy}" Margin="0,0,6,6"/>
                        <DatePicker Width="125" SelectedDate="{Binding FromDate}" Margin="0,0,6,6"/>
                        <DatePicker Width="125" SelectedDate="{Binding ToDate}" Margin="0,0,6,6"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" ToolTip="Reload backup history and status from the database." Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/>
                        <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" ToolTip="Reset backup history filters." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Automatic Backup Scheduler" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="{Binding AutomaticBackupEnabled, StringFormat=Enabled: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding AutomaticBackupIsRunning, StringFormat=Running: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding AutomaticBackupRetentionEnabled, StringFormat=Retention: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding AutomaticBackupDeletePhysicalFiles, StringFormat=Physical deletion: {0}}"/>
                    </WrapPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="{Binding AutomaticBackupLastRunAt, StringFormat=Last run: {0:dd-MMM-yyyy HH:mm}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding AutomaticBackupLastSuccessAt, StringFormat=Last success: {0:dd-MMM-yyyy HH:mm}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding AutomaticBackupLastFailureAt, StringFormat=Last failure: {0:dd-MMM-yyyy HH:mm}}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding AutomaticBackupLastMessage}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>

                    <WrapPanel>
                        <CheckBox Content="Enable automatic backup"
                                  IsChecked="{Binding AutomaticBackupEnabled}"
                                  IsEnabled="{Binding CanManageAutomaticBackups}"
                                  Margin="0,0,14,8"/>
                        <CheckBox Content="Run on startup"
                                  IsChecked="{Binding AutomaticBackupRunOnStartup}"
                                  IsEnabled="{Binding CanManageAutomaticBackups}"
                                  Margin="0,0,14,8"/>
                        <CheckBox Content="Create ZIP"
                                  IsChecked="{Binding AutomaticBackupCompress}"
                                  IsEnabled="{Binding CanManageAutomaticBackups}"
                                  Margin="0,0,14,8"/>
                        <CheckBox Content="Verify after creation"
                                  IsChecked="{Binding AutomaticBackupVerifyAfterCreation}"
                                  IsEnabled="{Binding CanManageAutomaticBackups}"
                                  Margin="0,0,14,8"/>
                        <CheckBox Content="Enable retention"
                                  IsChecked="{Binding AutomaticBackupRetentionEnabled}"
                                  IsEnabled="{Binding CanManageAutomaticBackups}"
                                  Margin="0,0,14,8"/>
                        <CheckBox Content="Delete physical files"
                                  IsChecked="{Binding AutomaticBackupDeletePhysicalFiles}"
                                  IsEnabled="{Binding CanManageAutomaticBackups}"
                                  Margin="0,0,14,8"/>
                    </WrapPanel>

                    <WrapPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Interval hours"/>
                            <TextBox Width="120"
                                     Text="{Binding AutomaticBackupIntervalHours, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanManageAutomaticBackups}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Initial delay seconds"/>
                            <TextBox Width="140"
                                     Text="{Binding AutomaticBackupInitialDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanManageAutomaticBackups}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Retention days"/>
                            <TextBox Width="120"
                                     Text="{Binding AutomaticBackupRetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanManageAutomaticBackups}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Max history rows"/>
                            <TextBox Width="130"
                                     Text="{Binding AutomaticBackupMaxHistoryRows, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanManageAutomaticBackups}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Destination folder"/>
                            <TextBox Width="360"
                                     Text="{Binding AutomaticBackupDestinationFolder, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanManageAutomaticBackups}"/>
                        </StackPanel>
                    </WrapPanel>

                    <TextBlock Text="Warning: physical deletion is disabled by default. When enabled, retention still keeps the live database, latest successful backup, restore safety backups, pending restore files, failed verification files, unsupported paths, and files outside the configured backup folder."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource DangerBrush}"
                               Margin="0,0,0,8"/>

                    <WrapPanel>
                        <Button Content="Run Backup Now"
                                Command="{Binding RunAutomaticBackupNowCommand}"
                                IsEnabled="{Binding CanManageAutomaticBackups}"
                                ToolTip="Run the automatic backup workflow immediately using the configured settings."
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,8"/>
                        <Button Content="Refresh Status"
                                Command="{Binding RefreshSchedulerStatusCommand}"
                                ToolTip="Reload automatic backup settings, permissions, and last-run status."
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,8"/>
                        <Button Content="Save Scheduler Settings"
                                Command="{Binding SaveSchedulerSettingsCommand}"
                                IsEnabled="{Binding CanManageAutomaticBackups}"
                                ToolTip="Persist automatic backup and retention settings."
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,8"/>
                        <Button Content="Preview Retention"
                                Command="{Binding PreviewRetentionCommand}"
                                ToolTip="List retention candidates and safety reasons before deletion."
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,8"/>
                        <Button Content="Apply Retention"
                                Command="{Binding ApplyRetentionCommand}"
                                IsEnabled="{Binding CanManageAutomaticBackups}"
                                ToolTip="Apply safe retention using the saved policy."
                                Style="{StaticResource DangerButton}"
                                Margin="0,0,8,8"/>
                        <Button Content="Open Backup Folder"
                                Command="{Binding OpenAutomaticBackupFolderCommand}"
                                ToolTip="Open the configured automatic backup destination folder."
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,8"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding RetentionCandidateCount, StringFormat=Retention candidates eligible: {0}}" Margin="0,4,0,4"/>
                    <DataGrid ItemsSource="{Binding RetentionCandidates}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Height="160">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat={}{0:dd-MMM-yyyy HH:mm}}" Width="125"/>
                            <DataGridTextColumn Header="Age" Binding="{Binding AgeDays}" Width="55"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeBytes, StringFormat={}{0:N0}}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Can Delete" Binding="{Binding CanDelete}" Width="80"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="220"/>
                            <DataGridTextColumn Header="Protection" Binding="{Binding CannotDeleteReason}" Width="260"/>
                            <DataGridTextColumn Header="File" Binding="{Binding BackupFilePath}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Database and Backup Ownership"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="{Binding ApplicationInstanceOwned, StringFormat=Application instance: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding DatabaseLockAvailable, StringFormat=Database lock available: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding BackupFolderLockAvailable, StringFormat=Backup folder lock available: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding RestoreLockAvailable, StringFormat=Restore lock available: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding SchedulerLockAvailable, StringFormat=Scheduler lock available: {0}}"/>
                    </WrapPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="{Binding DetectedStaleLockFiles, StringFormat=Detected stale lock files: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding OwnershipLastMessage}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                    </WrapPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Application instance" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ApplicationInstanceMessage}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Database lock" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DatabaseLockMessage}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Backup folder lock" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BackupFolderLockMessage}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Restore lock" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RestoreLockMessage}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Scheduler lock" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SchedulerLockMessage}" TextWrapping="Wrap"/>
                    </Grid>
                    <WrapPanel>
                        <Button Content="Refresh Ownership Status"
                                Command="{Binding RefreshOwnershipStatusCommand}"
                                ToolTip="Reload application, database, backup, restore, and scheduler lock status."
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,8"/>
                        <Button Content="Cleanup Stale Lock Files"
                                Command="{Binding CleanupStaleLockFilesCommand}"
                                IsEnabled="{Binding CanCleanupOwnershipLocks}"
                                ToolTip="Remove only expired safe ownership lock files. Admin or Super Admin required."
                                Style="{StaticResource DangerButton}"
                                Margin="0,0,8,8"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Release Database Relocation"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Copy-only workflow: creates a verified safety backup, copies the current SQLite database to the release runtime root, verifies the copy, and preserves the source database."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Current database" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RelocationCurrentDatabasePath}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Release target" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RelocationTargetDatabasePath}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Runtime data root" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RelocationRuntimeDataRoot}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Current mode" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RelocationRuntimeStorageMode}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Release root enabled" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RelocationUseReleaseDataRoot}"/>
                    </Grid>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="{Binding RelocationTargetExists, StringFormat=Target exists: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding RelocationCanRelocate, StringFormat=Preview valid: {0}}" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding RelocationCanManage, StringFormat=Can manage: {0}}"/>
                    </WrapPanel>
                    <TextBlock Text="Warning: this does not delete the old source database. If release-root startup is enabled, the app will use the copied database on the next launch."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource WarningBrush}"
                               Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Reason"/>
                            <TextBox Width="280"
                                     Text="{Binding RelocationReason, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding RelocationCanManage}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="Type RELOCATE"/>
                            <TextBox Width="150"
                                     Text="{Binding RelocationConfirmationText, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding RelocationCanManage}"/>
                        </StackPanel>
                        <CheckBox Content="Enable release data root after success"
                                  IsChecked="{Binding RelocationEnableReleaseDataRootAfterMove}"
                                  IsEnabled="{Binding RelocationCanManage}"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,10,12"/>
                        <Button Content="Preview Relocation"
                                Command="{Binding PreviewDatabaseRelocationCommand}"
                                ToolTip="Validate the release database target before any copy is attempted."
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,8"/>
                        <Button Content="Relocate Database"
                                Command="{Binding RelocateDatabaseCommand}"
                                IsEnabled="{Binding RelocationCanManage}"
                                ToolTip="Create a safety backup, copy the database, verify it, and switch release-root settings only after success."
                                Style="{StaticResource DangerButton}"
                                Margin="0,0,8,8"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding RelocationMessage}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding RelocationHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Height="140">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Started" Binding="{Binding StartedAt, StringFormat={}{0:dd-MMM-yyyy HH:mm}}" Width="125"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="95"/>
                            <DataGridTextColumn Header="Requested By" Binding="{Binding RequestedByUserName}" Width="130"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="180"/>
                            <DataGridTextColumn Header="Safety Backup" Binding="{Binding SafetyBackupPath}" Width="220"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetDatabasePath}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <DataGrid ItemsSource="{Binding BackupHistory}"
                          SelectedItem="{Binding SelectedBackup}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Height="260">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat={}{0:dd-MMM-yyyy HH:mm}}" Width="125"/>
                        <DataGridTextColumn Header="File Name" Binding="{Binding BackupFileName}" Width="*"/>
                        <DataGridTextColumn Header="Size (bytes)" Binding="{Binding BackupSizeBytes, StringFormat={}{0:N0}}" Width="95"/>
                        <DataGridTextColumn Header="Checksum" Binding="{Binding ChecksumSha256}" Width="160"/>
                        <DataGridTextColumn Header="Verification" Binding="{Binding VerificationStatus}" Width="90"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="115"/>
                        <DataGridTextColumn Header="Created By" Binding="{Binding CreatedBy}" Width="120"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <WrapPanel>
                        <Button Content="Verify Selected" Command="{Binding VerifySelectedCommand}" ToolTip="Run integrity and checksum verification on the selected backup." Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/>
                        <Button Content="Open Backup Folder" Command="{Binding OpenBackupFolderCommand}" ToolTip="Open the folder containing local backup files." Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                        <Button Content="View Details" Command="{Binding ViewDetailsCommand}" ToolTip="Show metadata, verification results, and file paths." Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                        <Button Content="Restore Selected" Command="{Binding RestoreSelectedCommand}" ToolTip="Open a validation preview before staging the selected backup." Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
