<Window x:Class="KicsitLibrary.Desktop.Views.PublisherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        mc:Ignorable="d"
        Title="Publishers Directory" Height="520" Width="800"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}"
        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,15" Padding="0,0,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Publishers Directory" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Manage publishing houses and contacts." FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
                <Button Content="Close" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Style="{StaticResource SecondaryButton}" Click="CloseButton_Click" Padding="15,6"/>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: List -->
            <Grid Grid.Column="0" Margin="0,0,15,0">
                <DataGrid ItemsSource="{Binding Publishers}" SelectedItem="{Binding SelectedPublisher, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Publisher Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="100"/>
                        <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="100"/>
                        <DataGridTemplateColumn Width="90" Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" ToolTip="Edit" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.SelectPublisherForEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="🗑️" ToolTip="Delete" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Right: Form -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding IsEditMode, Converter={local:BooleanToVisibilityConverter}, ConverterParameter='Edit Publisher Details;Add New Publisher'}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="{StaticResource PrimaryBrush}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Name -->
                            <TextBlock Text="Publisher Name" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- City -->
                            <TextBlock Text="City" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- Country -->
                            <TextBlock Text="Country" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- Contact -->
                            <TextBlock Text="Contact Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- Email -->
                            <TextBlock Text="Email Address" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- Website -->
                            <TextBlock Text="Website URL" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Website, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- Error Alert -->
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save / Cancel Button Panel -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Clear" Style="{StaticResource SecondaryButton}" Command="{Binding ClearFormCommand}" Margin="0,0,8,0" Padding="15,8"/>
                        <Button Content="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Padding="20,8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
