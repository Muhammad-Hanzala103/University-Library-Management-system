<UserControl x:Class="KicsitLibrary.Desktop.Views.StudentsManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loader Bar -->
        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" 
                     VerticalAlignment="Top" Margin="0,0,0,10"/>

        <!-- Top Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="Students" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Register Student" Style="{StaticResource PrimaryButton}" Command="{Binding AddStudentCommand}" Padding="15,6"/>
            </StackPanel>
        </Grid>

        <!-- Search Filters Panel -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- Search Query -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="Search (Name / Reg No / Roll No / CNIC)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Filter by Program -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                    <TextBlock Text="Program" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" ItemsSource="{Binding Programs}" SelectedItem="{Binding SelectedProgram}"/>
                </StackPanel>

                <!-- Filter by Department -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,10">
                    <TextBlock Text="Department" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}"/>
                </StackPanel>

                <!-- Filter by Batch -->
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Batch" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" ItemsSource="{Binding Batches}" SelectedItem="{Binding SelectedBatch}"/>
                </StackPanel>

                <!-- Clearance Status -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Library Clearance Status" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" ItemsSource="{Binding ClearanceStatuses}" SelectedItem="{Binding SelectedClearanceStatus}"/>
                </StackPanel>

                <!-- Active Status -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Account Status" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" SelectedValue="{Binding SelectedActiveStatus}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="All" Tag="{x:Null}"/>
                        <ComboBoxItem Content="Active Only" Tag="True"/>
                        <ComboBoxItem Content="Inactive Only" Tag="False"/>
                    </ComboBox>
                </StackPanel>

                <!-- Filler -->
                <Grid Grid.Row="1" Grid.Column="2" Margin="0,0,10,0"/>

                <!-- Action Buttons -->
                <Grid Grid.Row="1" Grid.Column="3" VerticalAlignment="Bottom" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Reset" Style="{StaticResource SecondaryButton}" Command="{Binding ClearFiltersCommand}" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Search" Style="{StaticResource PrimaryButton}" Command="{Binding SearchCommand}" Margin="5,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Students Data Grid -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding Students}" AutoGenerateColumns="False" IsReadOnly="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Registration No" Binding="{Binding RegistrationNumber}" Width="130"/>
                    <DataGridTextColumn Header="Roll No" Binding="{Binding RollNumber}" Width="100"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Program" Binding="{Binding Program}" Width="90"/>
                    <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="100"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    <DataGridTextColumn Header="Clearance" Binding="{Binding ClearanceStatus}" Width="110"/>
                    <DataGridTemplateColumn Width="180" Header="Actions">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="👤 Card" Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="11" Height="26"
                                            Command="{Binding DataContext.ViewProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="✏️" ToolTip="Edit Student Details" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"
                                            Command="{Binding DataContext.EditStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑️" ToolTip="Delete Student Account" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="8,0,0,0"
                                            Command="{Binding DataContext.DeleteStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Bottom Status / Errors bar -->
            <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,8,0,0"
                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
        </Grid>
    </Grid>
</UserControl>
