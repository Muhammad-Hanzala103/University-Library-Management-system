<UserControl x:Class="KicsitLibrary.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loader Bar -->
        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" 
                     VerticalAlignment="Top" Margin="0,0,0,10"/>

        <!-- Top Actions Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Welcome back, Librarian!" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextDarkBrush}"/>
            <Button Content="Refresh Statistics" Style="{StaticResource SecondaryButton}" 
                    ToolTip="Reload dashboard totals and recent activity."
                    Command="{Binding LoadStatsCommand}" HorizontalAlignment="Right" Padding="12,6"/>
        </Grid>

        <!-- Scrollable Stats Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,20">
                
                <!-- Section 1: Library Holdings -->
                <TextBlock Text="LIBRARY HOLDINGS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                <UniformGrid Columns="3" Margin="0,0,0,20">
                    
                    <!-- Total Books -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Total Accession Copies" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.TotalAccessionCopies}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Physical volumes in library" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="📚" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Unique Titles -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Total Unique Titles" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.TotalUniqueTitles}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Unique catalog records" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="📖" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Available Books -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Available Books" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.AvailableBooks}" Foreground="{StaticResource SuccessBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Ready for borrowing" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="✅" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Issued Books -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Issued Books" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.IssuedBooks}" Foreground="{StaticResource AccentBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Currently in circulation" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🔄" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Overdue Books -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Overdue Books" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.OverdueBooks}" Foreground="{StaticResource DangerBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Requires return warnings" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="⚠️" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Reserved Books -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Reserved Books" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.ReservedBooks}" Foreground="{StaticResource WarningBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Holds requested by members" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="📌" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Lost Books -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Lost Books" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.LostBooks}" Foreground="{StaticResource TextMutedBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Marked lost or unreturned" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="❌" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Damaged Books -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Damaged Books" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.DamagedBooks}" Foreground="{StaticResource DangerBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Volumes under repair/bad condition" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🤕" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>
                    
                    <!-- Today's Activity -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Today's Activity" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.TodayActivityCount}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="System operations logged today" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="⚡" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- Section 2: Library Users -->
                <TextBlock Text="LIBRARY MEMBERS &amp; FINES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,10"/>
                <UniformGrid Columns="3" Margin="0,0,0,20">
                    
                    <!-- Total Students -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Total Registered Students" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.TotalStudents}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Active students in library" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🎓" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Cleared Students -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Cleared Students" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.ClearedStudents}" Foreground="{StaticResource SuccessBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Cleared for graduation/leaving" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🎓" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Not Cleared Students -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Not Cleared Students" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.NotClearedStudents}" Foreground="{StaticResource DangerBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Have active issues or fines" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🎓" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Total Faculty -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Permanent Faculty" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.TotalFaculty}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Academic teaching staff" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="👨‍🏫" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Visiting Faculty -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Visiting Faculty" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.TotalVisitingFaculty}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Part-time teaching staff" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="👨‍🏫" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Staff -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="University Staff" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.TotalStaff}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Administrative staff members" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="💼" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- Section 3: Financials & Audit -->
                <TextBlock Text="FINANCIALS, VISITS &amp; AUDITS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,10"/>
                <UniformGrid Columns="3" Margin="0,0,0,20">
                    
                    <!-- Pending Fines -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Total Outstanding Fines" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.PendingFines, StringFormat='Rs. {0:N0}'}" Foreground="{StaticResource DangerBrush}" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Accumulated overdue fine logs" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🪙" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Fine Collected Today -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Fine Collected Today" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.FineCollectedToday, StringFormat='Rs. {0:N0}'}" Foreground="{StaticResource SuccessBrush}" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Received payments today" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🪙" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Fine Collected Month -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Collected This Month" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.FineCollectedThisMonth, StringFormat='Rs. {0:N0}'}" Foreground="{StaticResource SuccessBrush}" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Received payments this month" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🪙" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Furniture & Equipment -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Furniture &amp; Equipment" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.FurnitureEquipmentTotal}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Total cataloged items" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🪑" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- New Arrivals -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="New Arrivals (This Year)" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Text="{Binding Stats.NewArrivalsThisYear}" Foreground="{StaticResource SuccessBrush}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Acquisition entries this year" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🆕" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>

                    <!-- Visit / Audit -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Visits &amp; Audits" Style="{StaticResource SubtitleTextStyle}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding Stats.VisitRecords}" Foreground="{StaticResource PrimaryBrush}" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text=" Visits / " Foreground="{StaticResource TextMutedBrush}" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,2,2"/>
                                    <TextBlock Text="{Binding Stats.AuditRecords}" Foreground="{StaticResource PrimaryBrush}" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text=" Audits" Foreground="{StaticResource TextMutedBrush}" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="🔍" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.2"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- Section 4: Quick Actions -->
                <TextBlock Text="QUICK SHORTCUTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,10"/>
                <UniformGrid Columns="4" Margin="0,0,0,10">
                    <Button Style="{StaticResource SecondaryButton}" Content="Issue Material" Command="{Binding QuickIssueCommand}" ToolTip="Open the issue workflow." Margin="0,0,10,10" Padding="12,12"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Receive Material" Command="{Binding QuickReceiveCommand}" ToolTip="Open the return workflow." Margin="0,0,10,10" Padding="12,12"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Search Book Catalog" Command="{Binding QuickCatalogCommand}" ToolTip="Open catalog search and copy management." Margin="0,0,10,10" Padding="12,12"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Add Student" Command="{Binding QuickStudentsCommand}" ToolTip="Open student account management." Margin="0,0,0,10" Padding="12,12"/>
                    
                    <Button Style="{StaticResource SecondaryButton}" Content="Add Faculty/Staff" Command="{Binding QuickFacultyCommand}" ToolTip="Open faculty and staff account management." Margin="0,0,10,0" Padding="12,12"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Overdue Report" Command="{Binding QuickOverdueCommand}" ToolTip="Open overdue loans and reminders." Margin="0,0,10,0" Padding="12,12"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Fines Report" Command="{Binding QuickFinesCommand}" ToolTip="Open fine collection and adjustment records." Margin="0,0,10,0" Padding="12,12"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Settings" Command="{Binding QuickSettingsCommand}" Margin="0,0,0,0" Padding="12,12"/>
                </UniformGrid>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
