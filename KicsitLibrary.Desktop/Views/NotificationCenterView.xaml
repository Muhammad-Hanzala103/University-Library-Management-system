<UserControl x:Class="KicsitLibrary.Desktop.Views.NotificationCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}"
                     Margin="0,0,0,10"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="NOTIFICATION CENTER" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                <WrapPanel>
                    <Button Content="Refresh" Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
                    <Button Content="Send Selected Email" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SendSelectedEmailCommand}" Margin="0,0,8,0"/>
                    <Button Content="Retry Selected" Style="{StaticResource PrimaryButton}"
                            Command="{Binding RetrySelectedCommand}" Margin="0,0,8,0"/>
                    <Button Content="Send All Pending Emails" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SendAllPendingEmailsCommand}" Margin="0,0,8,0"/>
                    <Button Content="Validate Email Settings" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ValidateEmailSettingsCommand}" Margin="0,0,8,0"/>
                    <Button Content="Mark Selected As Read" Style="{StaticResource PrimaryButton}"
                            Command="{Binding MarkSelectedAsReadCommand}" Margin="0,0,8,0"/>
                    <Button Content="Clear Filters" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearFiltersCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Pending" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalPending}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Sent" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalSent}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Failed" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalFailed}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Retried" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalRetried}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12">
            <WrapPanel>
                <StackPanel Width="190" Margin="0,0,10,8">
                    <TextBlock Text="Search" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Style="{StaticResource StyledTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Width="105" Margin="0,0,10,8">
                    <TextBlock Text="Channel" FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding ChannelOptions}" SelectedItem="{Binding SelectedChannel}" Padding="8"/>
                </StackPanel>
                <StackPanel Width="175" Margin="0,0,10,8">
                    <TextBlock Text="Notification Type" FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding NotificationTypeOptions}" SelectedItem="{Binding SelectedNotificationType}" Padding="8"/>
                </StackPanel>
                <StackPanel Width="105" Margin="0,0,10,8">
                    <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Padding="8"/>
                </StackPanel>
                <StackPanel Width="120" Margin="0,0,10,8">
                    <TextBlock Text="Member Type" FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding MemberTypeOptions}" SelectedItem="{Binding SelectedMemberType}" Padding="8"/>
                </StackPanel>
                <StackPanel Width="125" Margin="0,0,10,8">
                    <TextBlock Text="From Date" FontSize="11" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding FromDate}"/>
                </StackPanel>
                <StackPanel Width="125" Margin="0,0,0,8">
                    <TextBlock Text="To Date" FontSize="11" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding ToDate}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Notifications}"
                      SelectedItem="{Binding SelectedNotification}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Member Type" Binding="{Binding MemberType}" Width="105"/>
                    <DataGridTextColumn Header="Recipient Name" Binding="{Binding RecipientName}" Width="150"/>
                    <DataGridTextColumn Header="Recipient Code" Binding="{Binding RecipientCode}" Width="120"/>
                    <DataGridTextColumn Header="Recipient Email" Binding="{Binding RecipientEmail}" Width="180"/>
                    <DataGridTextColumn Header="Notification Type" Binding="{Binding NotificationType}" Width="165"/>
                    <DataGridTextColumn Header="Channel" Binding="{Binding Channel}" Width="80"/>
                    <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="220"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="85"/>
                    <DataGridTextColumn Header="Retry Count" Binding="{Binding RetryCount}" Width="85"/>
                    <DataGridTextColumn Header="Failure Reason" Binding="{Binding FailureReason}" Width="190"/>
                    <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat='dd-MMM-yyyy HH:mm'}" Width="140"/>
                    <DataGridTextColumn Header="Last Attempt At" Binding="{Binding LastAttemptAt, StringFormat='dd-MMM-yyyy HH:mm'}" Width="140"/>
                    <DataGridTextColumn Header="Sent At" Binding="{Binding SentAt, StringFormat='dd-MMM-yyyy HH:mm'}" Width="140"/>
                    <DataGridTextColumn Header="Read At" Binding="{Binding ReadAt, StringFormat='dd-MMM-yyyy HH:mm'}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="5" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
