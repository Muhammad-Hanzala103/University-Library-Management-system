<Window x:Class="KicsitLibrary.Desktop.Views.InventoryDetailsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Inventory Details" Width="520" Height="500" WindowStartupLocation="CenterOwner"><Border Style="{StaticResource CardStyle}" Margin="15"><StackPanel><TextBlock Text="{Binding Item.ItemName}" FontSize="22" FontWeight="Bold"/><TextBlock Text="{Binding Item.ItemType, StringFormat=Type: {0}}"/><TextBlock Text="{Binding Item.Quantity, StringFormat=Total quantity: {0}}"/><TextBlock Text="{Binding Item.AvailableQuantity, StringFormat=Available: {0}}"/><TextBlock Text="{Binding Item.DamagedQuantity, StringFormat=Damaged: {0}}"/><TextBlock Text="{Binding Item.Location, StringFormat=Location: {0}}"/><TextBlock Text="{Binding Item.Condition, StringFormat=Condition: {0}}"/><TextBlock Text="{Binding Item.Supplier, StringFormat=Supplier: {0}}"/><TextBlock Text="{Binding Item.Remarks, StringFormat=Remarks: {0}}" TextWrapping="Wrap"/><TextBlock Text="{Binding Item.DocumentPath, StringFormat=Document metadata: {0}}" TextWrapping="Wrap"/></StackPanel></Border></Window>
