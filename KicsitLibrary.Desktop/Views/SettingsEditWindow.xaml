<Window x:Class="KicsitLibrary.Desktop.Views.SettingsEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        xmlns:helpers="clr-namespace:KicsitLibrary.Desktop.Helpers"
        Title="Edit Setting"
        Width="500"
        Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"/>
                <TextBlock Text="{Binding Key}"
                        FontSize="10"
                        Foreground="White"
                        Opacity="0.8"
                        Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <!-- Description -->
                <Border Visibility="{Binding Description, Converter={StaticResource StringVisibilityConverter}}"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,0,12"
                        Padding="12">
                    <TextBlock Text="{Binding Description}"
                            TextWrapping="Wrap"
                            Foreground="{StaticResource TextMutedBrush}"
                            FontSize="11"/>
                </Border>

                <!-- Category and Type -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="Category"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Margin="0,0,0,4"/>
                        <Border Padding="8"
                                Background="{StaticResource CardBgBrush}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="{Binding Category}"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                            Margin="6,0,0,0">
                        <TextBlock Text="Data Type"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Margin="0,0,0,4"/>
                        <Border Padding="8"
                                Background="{StaticResource CardBgBrush}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="{Binding DataType}"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Flags -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,12">
                    <Border Padding="8"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Icons/lock.png"
                                    Width="12"
                                    Margin="0,0,4,0"
                                   Visibility="{Binding IsSensitive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="Sensitive"
                                    FontSize="10"
                                    Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="8"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Icons/restart.png"
                                    Width="12"
                                    Margin="0,0,4,0"
                                   Visibility="{Binding RequiresRestart, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="Requires Restart"
                                    FontSize="10"
                                    Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Current Value -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Current Value"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4"/>
                    <Border Padding="8"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <TextBlock Text="{Binding CurrentValueMasked}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- New Value -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="New Value"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledTextBox}"
                              Visibility="{Binding IsSensitive, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    <PasswordBox x:Name="SensitiveInput"
                            Margin="0,0,0,4"
                                 Visibility="{Binding IsSensitive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Padding="8"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            helpers:PasswordHelper.BindPassword="True"
                            helpers:PasswordHelper.BoundPassword="{Binding NewValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Reason -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Reason (Optional)"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledTextBox}"
                            MinHeight="60"
                            AcceptsReturn="True"
                             ToolTip="Explain why you're changing this setting"/>
                </StackPanel>

                <!-- Default Value -->
                <Border Style="{StaticResource CardStyle}"
                        Margin="0,0,0,12"
                        Padding="12">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Reset to Default"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ResetToDefaultCommand}"
                                Margin="8,0,0,0"/>
                        <StackPanel>
                            <TextBlock Text="Default Value"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding DefaultValue}"
                                    FontSize="10"
                                    Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Validation -->
                <Border Visibility="{Binding ValidationMessage, Converter={StaticResource StringVisibilityConverter}}"
                        Background="{Binding IsValidationError, Converter={StaticResource BooleanToColorConverter}, ConverterParameter='#FEE2E2|#FEF3C7'}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        Padding="12"
                        Margin="0,0,0,12">
                    <TextBlock Text="{Binding ValidationMessage}"
                            TextWrapping="Wrap"
                            FontSize="10"
                               Foreground="{Binding IsValidationError, Converter={StaticResource BooleanToColorConverter}, ConverterParameter='#991B1B|#92400E'}"/>
                </Border>

                <!-- Status -->
                <Border Visibility="{Binding StatusMessage, Converter={StaticResource StringVisibilityConverter}}"
                        Background="#DBEAFE"
                        BorderThickness="1"
                        BorderBrush="#93C5FD"
                        Padding="12"
                        Margin="0,0,0,12">
                    <TextBlock Text="{Binding StatusMessage}"
                            TextWrapping="Wrap"
                            FontSize="10"
                            Foreground="#1E40AF"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                Margin="16,0">
            <Button Content="Validate"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ValidateAsyncCommand}"
                    Margin="0,0,6,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBooleanConverter}}"/>
        </StackPanel>

        <!-- Dialog Buttons -->
        <DockPanel Grid.Row="3"
                LastChildFill="False"
                Margin="16"
                Background="{StaticResource BgBrush}">
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"
                    Width="80"
                    Margin="6,0,0,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBooleanConverter}}"/>
            <Button DockPanel.Dock="Right"
                    Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveAsyncCommand}"
                    Width="80"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBooleanConverter}}"/>
        </DockPanel>
    </Grid>
</Window>
