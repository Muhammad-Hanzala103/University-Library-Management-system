<Window x:Class="KicsitLibrary.Desktop.Views.ConsumerProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        mc:Ignorable="d"
        x:Name="profileWindow"
        Title="Member Library Profile &amp; Digital Card" Height="680" Width="1000"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}"
        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Loader Bar -->
        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" 
                     VerticalAlignment="Top" Margin="0,0,0,10"/>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,20" Padding="0,0,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Member Library Account Profile" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="View active library items, fine statement, reservations, and print library cards." FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Close Profile" Style="{StaticResource SecondaryButton}" Click="Close_Click" Padding="15,6" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Library Card Preview -->
            <Border Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Top" Style="{StaticResource CardStyle}" Padding="0" Background="#F8F9FA" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Header / Institution Banner -->
                        <RowDefinition Height="60"/>
                        <!-- Photo & Details -->
                        <RowDefinition Height="Auto"/>
                        <!-- Barcode & QR Code Section -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Institution Banner -->
                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="4,4,0,0" Padding="15,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ILM-O-KUTUB CARD" Foreground="{StaticResource TextLightBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Dr A Q Khan Institute of CS &amp; IT" Foreground="{StaticResource TextMutedBrush}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Photo & Details -->
                    <StackPanel Grid.Row="1" Margin="20">
                        <!-- Profile Photo Grid -->
                        <Grid HorizontalAlignment="Center" Margin="0,0,0,15">
                            <!-- Custom Photo -->
                            <Border Width="110" Height="110" CornerRadius="55" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" Background="White" ClipToBounds="True"
                                    Visibility="{Binding PhotoPath, Converter={local:StringVisibilityConverter}}">
                                <Image Source="{Binding PhotoPath}" Stretch="UniformToFill"/>
                            </Border>
                            <!-- Initial Avatar fallback -->
                            <Border Width="110" Height="110" CornerRadius="55" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" Background="{StaticResource PrimaryBrush}"
                                    Visibility="{Binding PhotoPath, Converter={local:StringVisibilityConverter}, ConverterParameter=Inverse}">
                                <Grid>
                                    <TextBlock Text="👤" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Member Details list -->
                        <TextBlock Text="{Binding MemberName}" Foreground="{StaticResource PrimaryBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="{Binding ProgramOrDesignationValue}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,2,0,12"/>

                        <!-- Grid Table for Details -->
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding IdentifierLabel}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding IdentifierValue}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Department" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Department}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Clearance" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ClearanceDisplay}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"
                                       Foreground="{StaticResource SuccessBrush}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Library Status" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StatusDisplay}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Barcode & QR Code Section -->
                    <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="15" CornerRadius="0,0,4,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <!-- Vector Barcode -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Image Source="{Binding BarcodeImage}" Height="40" Stretch="Fill"/>
                                <TextBlock Text="{Binding IdentifierValue}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Vector QR Code -->
                            <Border Grid.Column="1" Width="70" Height="70" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="2" Padding="3" Background="White" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Image Source="{Binding QrCodeImage}" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Column: Historical Tabs -->
            <TabControl Grid.Column="1" Background="Transparent" BorderThickness="0">
                
                <!-- Tab 1: Active checkouts -->
                <TabItem Header="Active Issues">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Currently Issued Materials" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveIssues}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Accession No" Binding="{Binding AccessionNumber}" Width="100"/>
                                <DataGridTextColumn Header="Book Title" Binding="{Binding BookCopy.BookMaster.Title}" Width="2*"/>
                                <DataGridTextColumn Header="Issue Date" Binding="{Binding IssueDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Expected Return" Binding="{Binding ExpectedReturnDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Return History -->
                <TabItem Header="Return History">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Material Borrowing History Log" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ReturnHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Accession No" Binding="{Binding AccessionNumber}" Width="100"/>
                                <DataGridTextColumn Header="Book Title" Binding="{Binding BookCopy.BookMaster.Title}" Width="2*"/>
                                <DataGridTextColumn Header="Issued On" Binding="{Binding IssueDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Returned On" Binding="{Binding ReceiveRecord.ReceiveDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 3: Fine History -->
                <TabItem Header="Fines &amp; Dues">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Fines Statement Log" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Fines}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fine Date" Binding="{Binding CreatedAt, StringFormat={}{0:dd-MMM-yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Book Title" Binding="{Binding IssueRecord.BookCopy.BookMaster.Title}" Width="2*"/>
                                <DataGridTextColumn Header="Fine Amount (PKR)" Binding="{Binding FineAmount, StringFormat={}{0:N0}}" Width="120"/>
                                <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat={}{0:N0}}" Width="90"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding PaymentStatus}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 4: Reservation history -->
                <TabItem Header="Reservations">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Active Hold &amp; Material Reservations" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Reservations}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Reserved Date" Binding="{Binding ReservationDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                                <DataGridTextColumn Header="Book Title" Binding="{Binding BookMaster.Title}" Width="2*"/>
                                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                                <DataGridTextColumn Header="Reservation Status" Binding="{Binding Status}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Footer / Error messages -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,10,0,0"
                   Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
    </Grid>
</Window>
