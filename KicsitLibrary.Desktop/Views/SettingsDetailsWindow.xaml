<Window x:Class="KicsitLibrary.Desktop.Views.SettingsDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        Title="Setting Details"
        Width="500"
        Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"/>
                <TextBlock Text="{Binding Key}"
                        FontSize="10"
                        Foreground="White"
                        Opacity="0.8"
                        Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <!-- Description -->
                <Border Visibility="{Binding Description, Converter={local:StringVisibilityConverter}}"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,0,12"
                        Padding="12">
                    <TextBlock Text="{Binding Description}"
                            TextWrapping="Wrap"
                            Foreground="{StaticResource TextMutedBrush}"
                            FontSize="11"/>
                </Border>

                <!-- Category and Type -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="Category"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Margin="0,0,0,4"/>
                        <Border Padding="8"
                                Background="{StaticResource CardBgBrush}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="{Binding Category}"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                            Margin="6,0,0,0">
                        <TextBlock Text="Data Type"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Margin="0,0,0,4"/>
                        <Border Padding="8"
                                Background="{StaticResource CardBgBrush}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="{Binding DataType}"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Flags -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,12">
                    <Border Padding="8"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Icons/lock.png"
                                    Width="12"
                                    Margin="0,0,4,0"
                                   Visibility="{Binding IsSensitive, Converter={local:BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="Sensitive"
                                    FontSize="10"
                                    Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="8"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Icons/restart.png"
                                    Width="12"
                                    Margin="0,0,4,0"
                                   Visibility="{Binding RequiresRestart, Converter={local:BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="Requires Restart"
                                    FontSize="10"
                                    Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Current Value -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Current Value"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4"/>
                    <Border Padding="8"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <TextBlock Text="{Binding ValueMasked}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- Default Value -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Default Value"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4"/>
                    <Border Padding="8"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <TextBlock Text="{Binding DefaultValue}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- Last Updated -->
                <Grid Margin="0,0,0,12" Visibility="{Binding UpdatedAt, Converter={local:NullToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="Last Updated"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Margin="0,0,0,4"/>
                        <Border Padding="8"
                                Background="{StaticResource CardBgBrush}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                            Margin="6,0,0,0"
                            Visibility="{Binding UpdatedBy, Converter={local:StringVisibilityConverter}}">
                        <TextBlock Text="Updated By"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Margin="0,0,0,4"/>
                        <Border Padding="8"
                                Background="{StaticResource CardBgBrush}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="{Binding UpdatedBy}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <DockPanel Grid.Row="2"
                LastChildFill="False"
                Margin="16"
                Background="{StaticResource BgBrush}">
            <Button DockPanel.Dock="Right"
                    Content="Close"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding CloseCommand}"
                    Width="80"/>
        </DockPanel>
    </Grid>
</Window>
