<UserControl x:Class="KicsitLibrary.Desktop.Views.InventoryManagementView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10"><StackPanel><TextBlock Text="Inventory" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
   <WrapPanel Margin="0,10,0,0"><TextBox Width="170" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,6"/><ComboBox Width="120" ItemsSource="{Binding ItemTypes}" SelectedItem="{Binding SelectedItemType}" Margin="0,0,6,6"/><TextBox Width="110" Text="{Binding Condition}" Margin="0,0,6,6"/><TextBox Width="110" Text="{Binding Location}" Margin="0,0,6,6"/><DatePicker SelectedDate="{Binding FromDate}" Width="120" Margin="0,0,6,6"/><DatePicker SelectedDate="{Binding ToDate}" Width="120" Margin="0,0,6,6"/><CheckBox Content="Damaged" IsChecked="{Binding DamagedOnly}" Margin="0,5,8,6"/><CheckBox Content="Low quantity" IsChecked="{Binding LowQuantityOnly}" Margin="0,5,8,6"/><CheckBox Content="Include deleted" IsChecked="{Binding IncludeDeleted}" Margin="0,5,8,6"/><Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/><Button Content="Clear" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Add Item" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/></WrapPanel>
   <TextBlock Text="{Binding Summary.TotalQuantity, StringFormat=Total quantity: {0}}" /></StackPanel></Border>
  <Border Grid.Row="1" Style="{StaticResource CardStyle}"><DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns>
   <DataGridTextColumn Header="Item Name" Binding="{Binding ItemName}" Width="*"/><DataGridTextColumn Header="Type" Binding="{Binding ItemType}" Width="100"/><DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="55"/><DataGridTextColumn Header="Available" Binding="{Binding AvailableQuantity}" Width="70"/><DataGridTextColumn Header="Damaged" Binding="{Binding DamagedQuantity}" Width="70"/><DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="100"/><DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="90"/><DataGridTextColumn Header="Purchase Date" Binding="{Binding PurchaseDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="105"/><DataGridTextColumn Header="Price" Binding="{Binding PurchasePrice, StringFormat={}{0:N2}}" Width="85"/><DataGridTextColumn Header="Supplier" Binding="{Binding Supplier}" Width="110"/><DataGridTextColumn Header="Updated" Binding="{Binding LastUpdatedDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="105"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
  </DataGrid.Columns></DataGrid></Border>
  <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,10,0,0"><StackPanel><WrapPanel><Button Content="Edit" Command="{Binding EditCommand}" ToolTip="Edit the selected inventory item's details." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Details" Command="{Binding ViewDetailsCommand}" ToolTip="View inventory history and current quantities." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Adjust" Command="{Binding AdjustCommand}" ToolTip="Adjust quantities with a required reason and activity log." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><TextBox Width="50" Text="{Binding ActionQuantity}" Margin="0,0,6,6"/><TextBox Width="240" Text="{Binding ActionReason}" Margin="0,0,6,6"/><Button Content="Mark Damaged" Command="{Binding MarkDamagedCommand}" ToolTip="Move the entered quantity to damaged stock and record the reason." Style="{StaticResource DangerButton}" Margin="0,0,6,6"/><Button Content="Mark Repaired" Command="{Binding MarkRepairedCommand}" ToolTip="Return repaired quantity to available stock." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,6,6"/><Button Content="Restore" Command="{Binding RestoreCommand}" ToolTip="Restore a previously archived inventory item." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Export Excel" Command="{Binding ExportCommand}" ToolTip="Export the filtered inventory list to Excel." Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/></WrapPanel><TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/></StackPanel></Border>
 </Grid>
</UserControl>
