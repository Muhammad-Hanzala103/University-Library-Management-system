<UserControl x:Class="KicsitLibrary.Desktop.Views.StockVerificationView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10"><StackPanel><TextBlock Text="Physical Stock Verification" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/><WrapPanel Margin="0,10,0,0"><TextBox Width="170" Text="{Binding SearchText}" Margin="0,0,6,6"/><TextBox Width="105" Text="{Binding Category}" Margin="0,0,6,6"/><TextBox Width="105" Text="{Binding Department}" Margin="0,0,6,6"/><TextBox Width="70" Text="{Binding Rack}" Margin="0,0,6,6"/><TextBox Width="70" Text="{Binding Shelf}" Margin="0,0,6,6"/><CheckBox Content="Mismatch only" IsChecked="{Binding MismatchedOnly}" Margin="0,5,8,6"/><CheckBox Content="Unverified only" IsChecked="{Binding UnverifiedOnly}" Margin="0,5,8,6"/><Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/><Button Content="Clear" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Start New Session" Command="{Binding StartNewSessionCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/></WrapPanel><TextBlock Text="{Binding Summary.MismatchedCount, StringFormat=Mismatches: {0}}"/></StackPanel></Border>
  <Border Grid.Row="1" Style="{StaticResource CardStyle}"><DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Accession" Binding="{Binding AccessionNumber}" Width="100"/><DataGridTextColumn Header="Book Title" Binding="{Binding BookTitle}" Width="*"/><DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/><DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="100"/><DataGridTextColumn Header="Rack" Binding="{Binding Rack}" Width="60"/><DataGridTextColumn Header="Shelf" Binding="{Binding Shelf}" Width="60"/><DataGridTextColumn Header="Expected" Binding="{Binding ExpectedStatus}" Width="90"/><DataGridTextColumn Header="Actual" Binding="{Binding ActualStatus}" Width="90"/><DataGridCheckBoxColumn Header="Mismatch" Binding="{Binding IsMismatch}" Width="65"/><DataGridTextColumn Header="Verified At" Binding="{Binding VerifiedAt, StringFormat={}{0:dd-MMM HH:mm}}" Width="105"/><DataGridTextColumn Header="Verified By" Binding="{Binding VerifiedBy}" Width="100"/><DataGridTextColumn Header="Remarks" Binding="{Binding VerificationRemarks}" Width="180"/></DataGrid.Columns></DataGrid></Border>
  <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,10,0,0"><StackPanel><WrapPanel><ComboBox Width="120" ItemsSource="{Binding ActualStatuses}" SelectedItem="{Binding ActualStatus}" Margin="0,0,6,6"/><TextBox Width="220" Text="{Binding Remarks}" Margin="0,0,6,6"/><TextBox Width="220" Text="{Binding ReconciliationReason}" Margin="0,0,6,6"/><Button Content="Verify Selected" Command="{Binding VerifySelectedCommand}" ToolTip="Record the observed status for the selected physical copy." Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/><Button Content="Reconcile Selected" Command="{Binding ReconcileSelectedCommand}" ToolTip="Apply an approved reconciliation with a required reason." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Bulk Mark Unverified" Command="{Binding BulkMarkUnverifiedCommand}" ToolTip="Mark the currently filtered unverified copies in one operation." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Complete Session" Command="{Binding CompleteSessionCommand}" ToolTip="Close the active stock verification session and preserve its results." Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/><Button Content="Details" Command="{Binding ViewDetailsCommand}" ToolTip="Open verification history for the selected copy." Style="{StaticResource SecondaryButton}" Margin="0,0,6,6"/><Button Content="Export Excel" Command="{Binding ExportCommand}" ToolTip="Export the current stock verification results to Excel." Style="{StaticResource PrimaryButton}" Margin="0,0,6,6"/></WrapPanel><TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/></StackPanel></Border>
 </Grid>
</UserControl>
