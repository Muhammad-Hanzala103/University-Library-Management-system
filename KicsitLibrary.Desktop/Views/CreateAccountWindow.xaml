<Window x:Class="KicsitLibrary.Desktop.Views.CreateAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop.Views"
        mc:Ignorable="d"
        Title="Create Account" Height="650" MinHeight="600" Width="450" MinWidth="400"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border Background="{StaticResource BgBrush}" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="25" ShadowDepth="5" Direction="270" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/> 
                <RowDefinition Height="*"/>   
            </Grid.RowDefinitions>

            <!-- Header Panel -->
            <Border Grid.Row="0" CornerRadius="15,15,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0F766E" Offset="0.0"/>
                        <GradientStop Color="#115E59" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16"
                            Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" 
                            FontSize="18" FontWeight="Bold" Cursor="Hand" Click="CloseButton_Click" ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" Opacity="0.8"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Create Account" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Request access to the library system" Foreground="#99F6E4" FontSize="12" Margin="0,3,0,0" HorizontalAlignment="Center" Opacity="0.9"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Form Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="35,25,35,25">
                    
                    <TextBlock Text="Role Type" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" Margin="0,0,0,12" Height="38"/>

                    <TextBlock Text="Full Name" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StyledTextBox}" Margin="0,0,0,12" ToolTip="Enter your full legal name."/>

                    <TextBlock Text="Username" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StyledTextBox}" Margin="0,0,0,12" ToolTip="Enter a unique username."/>

                    <TextBlock Text="Email Address" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StyledTextBox}" Margin="0,0,0,12" ToolTip="Enter your primary email address."/>

                    <TextBlock Text="Phone Number (Optional)" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StyledTextBox}" Margin="0,0,0,12" ToolTip="Enter your phone number."/>

                    <TextBlock Text="Registration / Personnel ID (Optional)" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding LinkedId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StyledTextBox}" Margin="0,0,0,12" ToolTip="If you are a student or staff, enter your ID."/>

                    <TextBlock Text="Password" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordInput" Margin="0,0,0,12" ToolTip="Create a strong password."/>

                    <TextBlock Text="Confirm Password" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ConfirmPasswordInput" Margin="0,0,0,16" ToolTip="Re-enter your password."/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="12" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <Button Style="{StaticResource PrimaryButton}" Content="Submit Request" Height="42" FontSize="14"
                            Click="Submit_Click" Margin="0,0,0,10">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0F766E" Offset="0.0"/>
                                <GradientStop Color="#115E59" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                    <ProgressBar Height="4" IsIndeterminate="True" Background="Transparent" Foreground="{StaticResource AccentBrush}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,5,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
