<UserControl x:Class="KicsitLibrary.Desktop.Views.ReceiveMaterialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100" Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Loader Progress Bar -->
        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" 
                     VerticalAlignment="Top" Margin="0,0,0,10"/>

        <!-- Main Workspace Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Search Accession & Return Form -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,15,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="RECEIVE MATERIAL" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,15"/>

                    <!-- Accession Number Input -->
                    <TextBlock Text="Scan / Enter Accession Number *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource StyledTextBox}" Text="{Binding AccessionNumber, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Padding="12" Background="#F0F9FF" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" />
                        <Button Grid.Column="1" Content="🔍 Add" Style="{StaticResource PrimaryButton}" Command="{Binding LoadDetailsCommand}" ToolTip="Scan and add book to return list." Width="80" Margin="8,0,0,0" FontSize="14"/>
                    </Grid>

                    <!-- Fields shown only when items are added to list -->
                    <StackPanel Visibility="{Binding IsIssueFound, Converter={local:BooleanToVisibilityConverter}}">
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,5,0,15" Padding="0,10,0,0"/>

                        <!-- Payment Mode Selection -->
                        <TextBlock Text="Payment Mode *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox Height="36" ItemsSource="{Binding PaymentModes}" SelectedItem="{Binding PaymentMode}" Margin="0,0,0,12"/>

                        <!-- Waiver Reason -->
                        <StackPanel Visibility="{Binding IsWaiverVisible, Converter={local:BooleanToVisibilityConverter}}">
                            <TextBlock Text="Waiver / Discount Reason (Required) *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding WaiverReason, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- Remarks -->
                        <TextBlock Text="Staff Remarks" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>

                        <!-- Summary Cards -->
                        <Border Style="{StaticResource CardStyle}" BorderBrush="{StaticResource BorderBrush}" Background="#F8FAFC" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="RETURN SUMMARY" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Total Books:" FontSize="12" Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding PendingReturns.Count}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Total Fine Amount:" FontSize="12" Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding TotalFine, StringFormat='Rs. {0:N0}'}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <DockPanel Visibility="{Binding IsPayNowVisible, Converter={local:BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Amount to Pay:" FontSize="12" Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding TotalPaidAmount, StringFormat='Rs. {0:N0}'}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Actions -->
                        <Button Content="📥 Confirm Return &amp; Save All" Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmReturnCommand}" ToolTip="Process check-in for all items in the list." Height="40" Margin="0,0,0,8"/>
                        <Button Content="📄 Print Return Slip" Style="{StaticResource SecondaryButton}" Command="{Binding PrintReturnSlipCommand}" ToolTip="Print check-in transaction slip." Height="40" Margin="0,0,0,8"/>
                        <Button Content="🧹 Cancel / Clear List" Style="{StaticResource SecondaryButton}" Command="{Binding ClearAllCommand}" ToolTip="Clear all scanned items." Height="40"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RIGHT PANEL: Return Cart Grid & Fallback welcome -->
            <Grid Grid.Column="1">
                <!-- Fallback welcome panel -->
                <Border Style="{StaticResource CardStyle}" VerticalAlignment="Stretch" Margin="5,0,0,0"
                        Visibility="{Binding IsIssueFound, Converter={local:BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
                        <TextBlock Text="🔄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Receive Book Copies" Style="{StaticResource TitleTextStyle}" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Scan book copy accession numbers on the left to add them to the return list, select physical condition, and process bulk returns." 
                                   Style="{StaticResource SubtitleTextStyle}" HorizontalAlignment="Center" TextAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Scanned return list DataGrid -->
                <Border Style="{StaticResource CardStyle}" Margin="5,0,0,0"
                        Visibility="{Binding IsIssueFound, Converter={local:BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="PENDING RETURNS LIST" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="12" Margin="0,0,0,10"/>
                        
                        <DataGrid Grid.Row="1" ItemsSource="{Binding PendingReturns}"
                                  AutoGenerateColumns="False" IsReadOnly="False" RowHeight="38" HeadersVisibility="Column"
                                  Style="{StaticResource StyledDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Accession" Binding="{Binding AccessionNumber}" Width="100" IsReadOnly="True" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Book Title" Binding="{Binding BookTitle}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Borrower" Binding="{Binding BorrowerName}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding BorrowerTypeDisplay}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Due Date" Binding="{Binding DueDateDisplay}" Width="95" IsReadOnly="True" Foreground="{StaticResource TextMutedBrush}"/>
                                <DataGridTextColumn Header="Days Late" Binding="{Binding OverdueDays}" Width="80" IsReadOnly="True" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                
                                <!-- Editable Return Condition ComboBox -->
                                <DataGridTemplateColumn Header="Condition" Width="105">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedValue="{Binding SelectedCondition, UpdateSourceTrigger=PropertyChanged}" 
                                                      SelectedValuePath="Content" Height="26" VerticalAlignment="Center">
                                                <ComboBoxItem Content="Normal"/>
                                                <ComboBoxItem Content="Damaged"/>
                                                <ComboBoxItem Content="Lost"/>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Fine (Rs.)" Binding="{Binding CalculatedFine, StringFormat='{}{0:N0}'}" Width="85" IsReadOnly="True" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>

                                <!-- Actions Column -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="❌" Style="{StaticResource IconButton}" 
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Remove this item from the list"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status / Message Display Bar -->
        <Border Grid.Row="2" Margin="0,15,0,0"
                Visibility="{Binding StatusMessage, Converter={local:StringVisibilityConverter}}">
            <TextBox Text="{Binding StatusMessage}" Style="{StaticResource StyledTextBox}" 
                     FontFamily="Consolas, Courier New" FontSize="12" IsReadOnly="True" 
                     Height="120" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
        </Border>
    </Grid>
</UserControl>
