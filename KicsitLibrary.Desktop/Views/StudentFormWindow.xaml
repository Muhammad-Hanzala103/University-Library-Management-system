<Window x:Class="KicsitLibrary.Desktop.Views.StudentFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        mc:Ignorable="d"
        x:Name="studentWindow"
        Title="{Binding WindowTitle}" Height="680" Width="950"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}"
        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,20" Padding="0,0,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Enter student information to configure their university library access account." FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
        </Border>

        <!-- Form Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: Academic Details -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="ACADEMIC &amp; REGISTRATION INFO" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>

                    <!-- Registration Number -->
                    <TextBlock Text="Registration Number *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding RegistrationNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Roll Number -->
                    <TextBlock Text="Roll Number *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding RollNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Admission Number -->
                    <TextBlock Text="Admission Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding AdmissionNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Program -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Program *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding Programs}" SelectedItem="{Binding SelectedProgram}"/>
                        </StackPanel>
                        <!-- Department -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Department *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Batch -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Batch *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding Batches}" SelectedItem="{Binding SelectedBatch}"/>
                        </StackPanel>
                        <!-- Semester -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Semester" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Semester, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Session -->
                    <TextBlock Text="Session" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Session, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Page Number -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Register Page Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding PageNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                        <!-- Register Number -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Register Serial Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding RegisterNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Column 2: Personal details -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="PERSONAL &amp; CONTACT DETAILS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>

                    <!-- Student Name -->
                    <TextBlock Text="Student Full Name *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Father Name -->
                    <TextBlock Text="Father's Name" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding FatherName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- CNIC -->
                    <TextBlock Text="CNIC Number (xxxxx-xxxxxxx-x)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Cnic, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Text="Email Address" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Phone -->
                    <TextBlock Text="Phone Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Address -->
                    <TextBlock Text="Residential Address" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Height="70"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Column 3: Profile image & Settings -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="PROFILE PHOTO &amp; SYSTEM STATUS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>

                <!-- Image Picker -->
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Height="180" Background="#F8F9FA" Margin="0,0,0,10">
                    <Grid>
                        <!-- If photo path is not empty -->
                        <Image Source="{Binding PhotoPath}" Stretch="Uniform" Margin="5"
                               Visibility="{Binding PhotoPath, Converter={local:StringVisibilityConverter}}"/>
                        
                        <!-- Fallback empty indicator -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding PhotoPath, Converter={local:StringVisibilityConverter}, ConverterParameter=Inverse}">
                            <TextBlock Text="📷" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="No Profile Photo" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Button Content="Choose Photo..." Style="{StaticResource SecondaryButton}" Command="{Binding SelectPhotoCommand}" Margin="0,0,0,20"/>

                <!-- Account Settings -->
                <TextBlock Text="ACCOUNT PERMISSIONS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                
                <CheckBox Content="Account Active (Allowed Access)" IsChecked="{Binding ActiveStatus}" Margin="0,0,0,8" VerticalContentAlignment="Center"/>
                
                <TextBlock Text="Library Clearance Status" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,5,0,4"/>
                <ComboBox Height="36" SelectedValue="{Binding ClearanceStatus}" SelectedValuePath="Tag">
                    <ComboBoxItem Content="Not Cleared (Active Student)" Tag="{x:Static CoreEnums:ClearanceStatus.NotCleared}" 
                                  xmlns:CoreEnums="clr-namespace:KicsitLibrary.Core.Enums;assembly=KicsitLibrary.Core"/>
                    <ComboBoxItem Content="Cleared (Graduated/Leaving)" Tag="{x:Static CoreEnums:ClearanceStatus.Cleared}" 
                                  xmlns:CoreEnums="clr-namespace:KicsitLibrary.Core.Enums;assembly=KicsitLibrary.Core"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Padding="0,15,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status/Error Message -->
                <TextBlock Grid.Column="0" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" CommandParameter="{Binding ElementName=studentWindow}" Width="100" Margin="0,0,10,0"/>
                    <Button Content="Save Student" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" CommandParameter="{Binding ElementName=studentWindow}" Width="130"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
