<Window x:Class="KicsitLibrary.Desktop.Views.ReservationQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reservation Queue" Height="520" Width="900"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="{Binding BookTitle}" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </DockPanel>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Queue}" SelectedItem="{Binding SelectedReservation}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding QueuePosition}" Width="45"/>
                    <DataGridTextColumn Header="Reservation" Binding="{Binding ReservationNumber}" Width="150"/>
                    <DataGridTextColumn Header="Member" Binding="{Binding MemberName}" Width="*"/>
                    <DataGridTextColumn Header="Code" Binding="{Binding MemberCode}" Width="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                    <DataGridTextColumn Header="Reserved" Binding="{Binding ReservationDate, StringFormat={}{0:dd-MMM-yyyy HH:mm}}" Width="135"/>
                    <DataGridTextColumn Header="Expires" Binding="{Binding ExpiryDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="105"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <StackPanel>
                <WrapPanel>
                    <TextBox Width="260" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8"/>
                    <Button Content="Mark First Available" Command="{Binding MarkAvailableCommand}" ToolTip="Assign the available copy to the first eligible queue entry." Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/>
                    <Button Content="Fulfill Selected" Command="{Binding FulfillCommand}" ToolTip="Complete the selected queue entry after issue." Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/>
                    <Button Content="Cancel Selected" Command="{Binding CancelCommand}" ToolTip="Cancel this queue entry while preserving its record." Style="{StaticResource DangerButton}" Margin="0,0,8,8"/>
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
