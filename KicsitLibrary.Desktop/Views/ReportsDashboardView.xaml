<UserControl x:Class="KicsitLibrary.Desktop.Views.ReportsDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             xmlns:views="clr-namespace:KicsitLibrary.Desktop.Views"
             Background="Transparent">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.4"
                                     DecelerationRatio="0.8"/>
                    <ThicknessAnimation Storyboard.TargetName="MainGrid"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,15,0,0" To="0,0,0,0" Duration="0:0:0.4"
                                        DecelerationRatio="0.8"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}"
                     Margin="0,0,0,10"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="REPORTS" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="{Binding VisibleReportCount}"/>
                            <Run Text=" report(s)"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBox DockPanel.Dock="Right" Width="250"
                             Style="{StaticResource StyledTextBox}"
                             Text="{Binding ReportSearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search reports by name or description"/>
                </DockPanel>

                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ReportGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding Reports}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip="Select this report and load its available filters."
                                                        CommandParameter="{Binding}"
                                                        Width="175" Height="72" Margin="0,0,10,8" Padding="8">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{local:ObjectEqualityConverter}">
                                                                            <Binding Path="." />
                                                                            <Binding Path="DataContext.SelectedReport" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Background" Value="#EFF6FF" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                    <Setter Property="BorderThickness" Value="1.5" />
                                                                    <Setter Property="Foreground" Value="#1E40AF" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="9"
                                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Refresh Preview" Style="{StaticResource PrimaryButton}"
                                ToolTip="Run the selected report with the current filters."
                                Command="{Binding RefreshPreviewCommand}" Margin="0,0,8,0"/>
                        <Button Content="Clear Filters" Style="{StaticResource SecondaryButton}"
                                ToolTip="Reset all filters for the selected report."
                                Command="{Binding ClearFiltersCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedReport.Title}" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding FilterInputs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,10,8">
                                <StackPanel Width="190"
                                            Visibility="{Binding IsText, Converter={local:BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Width="165"
                                            Visibility="{Binding IsEnum, Converter={local:BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedOption}" Padding="6"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsDateRange, Converter={local:BooleanToVisibilityConverter}}">
                                    <StackPanel Width="145" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Label, StringFormat='{}{0} From'}" FontSize="11" FontWeight="SemiBold"/>
                                        <DatePicker SelectedDate="{Binding FromDate}"/>
                                    </StackPanel>
                                    <StackPanel Width="145">
                                        <TextBlock Text="{Binding Label, StringFormat='{}{0} To'}" FontSize="11" FontWeight="SemiBold"/>
                                        <DatePicker SelectedDate="{Binding ToDate}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsNumberRange, Converter={local:BooleanToVisibilityConverter}}">
                                    <StackPanel Width="105" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Label, StringFormat='{}{0} Min'}" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding TextValue}"/>
                                    </StackPanel>
                                    <StackPanel Width="105">
                                        <TextBlock Text="{Binding Label, StringFormat='{}{0} Max'}" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding SecondaryTextValue}"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding BooleanValue}"
                                          VerticalAlignment="Center" Margin="0,18,0,0"
                                          Visibility="{Binding IsBoolean, Converter={local:BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <WrapPanel Margin="0,12,0,0">
                    <Button Style="{StaticResource SecondaryButton}"
                            ToolTip="Export the current report rows as a CSV file."
                            Command="{Binding ExportCsvCommand}" Margin="0,0,8,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,6,0"/>
                            <TextBlock Text="Export CSV" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            ToolTip="Generate a formatted Excel workbook for the current report."
                            Command="{Binding ExportExcelCommand}" Margin="0,0,8,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" Margin="0,0,6,0"/>
                            <TextBlock Text="Export Excel" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            ToolTip="Generate a PDF file for the current report."
                            Command="{Binding ExportPdfCommand}" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📕" Margin="0,0,6,0"/>
                            <TextBlock Text="Export PDF" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,12,0">
                <views:ReportPreviewView DataContext="{Binding Preview}"/>
            </Border>
            
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="REPORT VISUALIZATION" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="12"/>
                        <TextBlock Text="Summary metrics visual distribution" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <!-- Placeholder when no report is loaded or empty -->
                        <TextBlock Text="No preview data available to chart." 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                   Visibility="{Binding Preview.IsEmpty, Converter={local:BooleanToVisibilityConverter}}"/>
                                   
                        <!-- Chart content when loaded -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                      Visibility="{Binding Preview.IsEmpty, Converter={local:BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                            <ItemsControl ItemsSource="{Binding Preview.SummaryItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,14">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left" Text="{Binding Key}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Value}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                            </DockPanel>
                                            
                                            <!-- Lightweight visual bar representing the metric -->
                                            <Grid Margin="0,4,0,0" Height="8">
                                                <Border Background="#F1F5F9" CornerRadius="4"/>
                                                <ProgressBar Value="{Binding Value, Mode=OneWay, Converter={local:SummaryValueConverter}}" 
                                                             Maximum="100" 
                                                             Height="8"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Foreground="{StaticResource AccentBrush}">
                                                    <ProgressBar.Template>
                                                        <ControlTemplate TargetType="ProgressBar">
                                                            <Grid>
                                                                <Border x:Name="PART_Track" Background="Transparent" CornerRadius="4"/>
                                                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="4" HorizontalAlignment="Left"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </ProgressBar.Template>
                                                </ProgressBar>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
