<UserControl x:Class="KicsitLibrary.Desktop.Views.ReportsDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             xmlns:views="clr-namespace:KicsitLibrary.Desktop.Views"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}"
                     Margin="0,0,0,10"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="REPORTS" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="{Binding VisibleReportCount}"/>
                            <Run Text=" report(s)"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBox DockPanel.Dock="Right" Width="250"
                             Style="{StaticResource StyledTextBox}"
                             Text="{Binding ReportSearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search reports by name or description"/>
                </DockPanel>

                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ReportGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding Reports}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip="Select this report and load its available filters."
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Width="175" Height="72" Margin="0,0,10,8" Padding="8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                                   TextWrapping="Wrap" TextAlignment="Center"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="9"
                                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="{Binding SelectedReport.Title}" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Refresh Preview" Style="{StaticResource PrimaryButton}"
                                ToolTip="Run the selected report with the current filters."
                                Command="{Binding RefreshPreviewCommand}" Margin="0,0,8,0"/>
                        <Button Content="Clear Filters" Style="{StaticResource SecondaryButton}"
                                ToolTip="Reset all filters for the selected report."
                                Command="{Binding ClearFiltersCommand}"/>
                    </StackPanel>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding FilterInputs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,10,8">
                                <StackPanel Width="190"
                                            Visibility="{Binding IsText, Converter={local:BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Width="165"
                                            Visibility="{Binding IsEnum, Converter={local:BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedOption}" Padding="6"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsDateRange, Converter={local:BooleanToVisibilityConverter}}">
                                    <StackPanel Width="145" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Label, StringFormat={}{0} From}" FontSize="11" FontWeight="SemiBold"/>
                                        <DatePicker SelectedDate="{Binding FromDate}"/>
                                    </StackPanel>
                                    <StackPanel Width="145">
                                        <TextBlock Text="{Binding Label, StringFormat={}{0} To}" FontSize="11" FontWeight="SemiBold"/>
                                        <DatePicker SelectedDate="{Binding ToDate}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsNumberRange, Converter={local:BooleanToVisibilityConverter}}">
                                    <StackPanel Width="105" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Label, StringFormat={}{0} Min}" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding TextValue}"/>
                                    </StackPanel>
                                    <StackPanel Width="105">
                                        <TextBlock Text="{Binding Label, StringFormat={}{0} Max}" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding SecondaryTextValue}"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding BooleanValue}"
                                          VerticalAlignment="Center" Margin="0,18,0,0"
                                          Visibility="{Binding IsBoolean, Converter={local:BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <WrapPanel Margin="0,5,0,0">
                    <Button Content="Export CSV" Style="{StaticResource SecondaryButton}"
                            ToolTip="Export the current report rows as a CSV file."
                            Command="{Binding ExportCsvCommand}" Margin="0,0,8,0"/>
                    <Button Content="Export Excel" Style="{StaticResource SecondaryButton}"
                            ToolTip="Generate a formatted Excel workbook for the current report."
                            Command="{Binding ExportExcelCommand}" Margin="0,0,8,0"/>
                    <Button Content="Export PDF" Style="{StaticResource SecondaryButton}"
                            ToolTip="Generate a PDF file for the current report."
                            Command="{Binding ExportPdfCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="12">
            <views:ReportPreviewView DataContext="{Binding Preview}"/>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
