<UserControl x:Class="KicsitLibrary.Desktop.Views.ReportsDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             xmlns:views="clr-namespace:KicsitLibrary.Desktop.Views"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}"
                     Margin="0,0,0,10"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="REPORTS &amp; EXPORTS" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding Reports}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="165" Height="70" Margin="0,0,10,10"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding Description}" FontSize="9"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="{Binding SelectedReport.Title}" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Refresh Preview" Style="{StaticResource PrimaryButton}"
                                Command="{Binding RefreshPreviewCommand}" Margin="0,0,8,0"/>
                        <Button Content="Clear Filters" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearFiltersCommand}"/>
                    </StackPanel>
                </DockPanel>

                <WrapPanel>
                    <StackPanel Width="220" Margin="0,0,10,8">
                        <TextBlock Text="Search Text" FontSize="11" FontWeight="SemiBold"/>
                        <TextBox Style="{StaticResource StyledTextBox}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <WrapPanel Visibility="{Binding IsCatalogReport, Converter={local:BooleanToVisibilityConverter}}">
                        <StackPanel Width="145" Margin="0,0,10,8">
                            <TextBlock Text="Category" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Category}"/>
                        </StackPanel>
                        <StackPanel Width="145" Margin="0,0,10,8">
                            <TextBlock Text="Department" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Department}"/>
                        </StackPanel>
                        <StackPanel Width="145" Margin="0,0,10,8">
                            <TextBlock Text="Literature Category" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding LiteratureCategory}"/>
                        </StackPanel>
                        <StackPanel Width="145" Margin="0,0,10,8">
                            <TextBlock Text="Author" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Author}"/>
                        </StackPanel>
                        <StackPanel Width="145" Margin="0,0,10,8">
                            <TextBlock Text="Publisher" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Publisher}"/>
                        </StackPanel>
                        <StackPanel Width="135" Margin="0,0,10,8">
                            <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding BookStatusOptions}"
                                      SelectedItem="{Binding SelectedStatus}" Padding="6"/>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Visibility="{Binding IsIssuedReport, Converter={local:BooleanToVisibilityConverter}}">
                        <StackPanel Width="135" Margin="0,0,10,8">
                            <TextBlock Text="Member Type" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding MemberTypeOptions}"
                                      SelectedItem="{Binding SelectedMemberType}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="140" Margin="0,0,10,8">
                            <TextBlock Text="From Issue Date" FontSize="11" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding FromDate}"/>
                        </StackPanel>
                        <StackPanel Width="140" Margin="0,0,10,8">
                            <TextBlock Text="To Issue Date" FontSize="11" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding ToDate}"/>
                        </StackPanel>
                        <CheckBox Content="Overdue Only" IsChecked="{Binding OverdueOnly}"
                                  VerticalAlignment="Center" Margin="0,12,10,8"/>
                    </WrapPanel>

                    <WrapPanel Visibility="{Binding IsOverdueReport, Converter={local:BooleanToVisibilityConverter}}">
                        <StackPanel Width="135" Margin="0,0,10,8">
                            <TextBlock Text="Member Type" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding MemberTypeOptions}"
                                      SelectedItem="{Binding SelectedMemberType}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="100" Margin="0,0,10,8">
                            <TextBlock Text="Min Days" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding MinimumDays}"/>
                        </StackPanel>
                        <StackPanel Width="100" Margin="0,0,10,8">
                            <TextBlock Text="Max Days" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding MaximumDays}"/>
                        </StackPanel>
                        <StackPanel Width="110" Margin="0,0,10,8">
                            <TextBlock Text="Min Fine" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding MinimumAmount}"/>
                        </StackPanel>
                        <StackPanel Width="110" Margin="0,0,10,8">
                            <TextBlock Text="Max Fine" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding MaximumAmount}"/>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Visibility="{Binding IsFineReport, Converter={local:BooleanToVisibilityConverter}}">
                        <StackPanel Width="135" Margin="0,0,10,8">
                            <TextBlock Text="Member Type" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding MemberTypeOptions}"
                                      SelectedItem="{Binding SelectedMemberType}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="135" Margin="0,0,10,8">
                            <TextBlock Text="Payment Status" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding FineStatusOptions}"
                                      SelectedItem="{Binding SelectedStatus}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="130" Margin="0,0,10,8">
                            <TextBlock Text="From Date" FontSize="11" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding FromDate}"/>
                        </StackPanel>
                        <StackPanel Width="130" Margin="0,0,10,8">
                            <TextBlock Text="To Date" FontSize="11" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding ToDate}"/>
                        </StackPanel>
                        <StackPanel Width="110" Margin="0,0,10,8">
                            <TextBlock Text="Min Amount" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding MinimumAmount}"/>
                        </StackPanel>
                        <StackPanel Width="110" Margin="0,0,10,8">
                            <TextBlock Text="Max Amount" FontSize="11" FontWeight="SemiBold"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding MaximumAmount}"/>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Visibility="{Binding IsNotificationReport, Converter={local:BooleanToVisibilityConverter}}">
                        <StackPanel Width="125" Margin="0,0,10,8">
                            <TextBlock Text="Member Type" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding MemberTypeOptions}"
                                      SelectedItem="{Binding SelectedMemberType}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="110" Margin="0,0,10,8">
                            <TextBlock Text="Channel" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding ChannelOptions}"
                                      SelectedItem="{Binding SelectedChannel}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="170" Margin="0,0,10,8">
                            <TextBlock Text="Notification Type" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding NotificationTypeOptions}"
                                      SelectedItem="{Binding SelectedNotificationType}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="115" Margin="0,0,10,8">
                            <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding NotificationStatusOptions}"
                                      SelectedItem="{Binding SelectedStatus}" Padding="6"/>
                        </StackPanel>
                        <StackPanel Width="130" Margin="0,0,10,8">
                            <TextBlock Text="From Date" FontSize="11" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding FromDate}"/>
                        </StackPanel>
                        <StackPanel Width="130" Margin="0,0,10,8">
                            <TextBlock Text="To Date" FontSize="11" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding ToDate}"/>
                        </StackPanel>
                    </WrapPanel>
                </WrapPanel>

                <WrapPanel Margin="0,5,0,0">
                    <Button Content="Export CSV" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportCsvCommand}" Margin="0,0,8,0"/>
                    <Button Content="Export Excel" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportExcelCommand}" Margin="0,0,8,0"/>
                    <Button Content="Export PDF" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportPdfCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="12">
            <views:ReportPreviewView DataContext="{Binding Preview}"/>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                       FontWeight="SemiBold" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
