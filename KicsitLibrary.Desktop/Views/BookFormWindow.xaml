<Window x:Class="KicsitLibrary.Desktop.Views.BookFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="750" Width="1050"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}"
        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,20" Padding="0,0,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Enter all required details to publish a new material in the library catalog." FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
        </Border>

        <!-- Form Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: General Details -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="GENERAL DETAILS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>

                    <!-- Title -->
                    <TextBlock Text="Material Title *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Material Type -->
                    <TextBlock Text="Material Type *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding MaterialTypes}" SelectedItem="{Binding SelectedMaterialType}"/>

                    <!-- Subtitle -->
                    <TextBlock Text="Subtitle" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding SubTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Edition -->
                    <TextBlock Text="Edition" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Edition, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Series -->
                    <TextBlock Text="Series" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Series, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Language -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Language" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                        <!-- Format -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Format (e.g. Hard, PDF)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Format, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Binding Type -->
                    <TextBlock Text="Binding Type" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" Margin="0,0,0,12" SelectedValue="{Binding BindingType}" SelectedValuePath="Content">
                        <ComboBoxItem Content="Hardcover"/>
                        <ComboBoxItem Content="Paperback"/>
                        <ComboBoxItem Content="Spiral Bound"/>
                        <ComboBoxItem Content="Digital / E-Book"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>

                    <!-- Keywords -->
                    <TextBlock Text="Keywords / Tags (comma separated)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Keywords, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Contents -->
                    <TextBlock Text="Table of Contents Summary" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Contents, UpdateSourceTrigger=PropertyChanged}" Height="80" 
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Column 2: Classifications & Authors -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="CLASSIFICATION &amp; AUTHORS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>

                    <!-- Category -->
                    <TextBlock Text="Category Section *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding Categories}" 
                              SelectedValue="{Binding SelectedCategoryId}" SelectedValuePath="Id" DisplayMemberPath="Name"/>

                    <!-- Department Category -->
                    <TextBlock Text="Department Category *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding DepartmentCategories}" 
                              SelectedValue="{Binding SelectedDepartmentCategoryId}" SelectedValuePath="Id" DisplayMemberPath="Name"/>

                    <!-- Literature Category -->
                    <TextBlock Text="Literature Category *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding LiteratureCategories}" 
                              SelectedValue="{Binding SelectedLiteratureCategoryId}" SelectedValuePath="Id" DisplayMemberPath="Name"/>

                    <!-- Publisher -->
                    <TextBlock Text="Publisher *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding Publishers}" 
                              SelectedValue="{Binding SelectedPublisherId}" SelectedValuePath="Id" DisplayMemberPath="Name"/>

                    <!-- Authors Multi-Select -->
                    <TextBlock Text="Authors (Select one or more) *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Height="140" Margin="0,0,0,12">
                        <ListBox ItemsSource="{Binding Authors}" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Author.Name}" IsChecked="{Binding IsSelected}" Margin="5,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Subjects -->
                    <TextBlock Text="Subject Heading" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- ISBN -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="ISBN" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding ISBN, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/>
                                <Button Grid.Column="1" Content="Fetch" Style="{StaticResource SecondaryButton}" Command="{Binding FetchMetadataCommand}" Padding="10,6" ToolTip="Fetch details by ISBN from online libraries"/>
                            </Grid>
                        </StackPanel>
                        <!-- ISSN -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="ISSN" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding ISSN, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Classification -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Class Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding ClassificationNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                        <!-- Call Number -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Call Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding CallNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Column 3: Procurement & Uploads -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="PROCUREMENT DETAILS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>

                            <!-- Accession Type -->
                            <TextBlock Text="Accession Type" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox Height="36" Margin="0,0,0,12" SelectedValue="{Binding AccessionType}" SelectedValuePath="Content">
                                <ComboBoxItem Content="Purchase"/>
                                <ComboBoxItem Content="Donation / Gift"/>
                                <ComboBoxItem Content="Exchange"/>
                                <ComboBoxItem Content="Institutional Copy"/>
                            </ComboBox>

                            <!-- Purchase Date -->
                            <TextBlock Text="Procurement Date" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <DatePicker Height="36" Margin="0,0,0,12" SelectedDate="{Binding PurchaseDate}"/>

                            <!-- Purchase Price -->
                            <TextBlock Text="Purchase Price (PKR)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- Supplier -->
                            <TextBlock Text="Supplier Name" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                            <TextBlock Text="UPLOADS &amp; ATTACHMENTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,15"/>

                            <!-- Invoice File Upload -->
                            <TextBlock Text="Invoice Document (PDF, Image)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding InvoiceFilePath}" IsReadOnly="True" Margin="0,0,6,0"/>
                                <Button Grid.Column="1" Content="Upload" Style="{StaticResource SecondaryButton}" Command="{Binding UploadInvoiceCommand}" Padding="10,6"/>
                            </Grid>

                            <!-- Book Image Upload -->
                            <TextBlock Text="Book Cover Image (JPG, PNG)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding BookCoverPath}" IsReadOnly="True" Margin="0,0,6,0"/>
                                <Button Grid.Column="1" Content="Select" Style="{StaticResource SecondaryButton}" Command="{Binding UploadCoverCommand}" Padding="10,6"/>
                            </Grid>

                            <!-- Error Alert -->
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save & Cancel Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Margin="0,0,8,0" Padding="15,8"/>
                        <Button Content="Save Catalog Record" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Padding="20,8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
