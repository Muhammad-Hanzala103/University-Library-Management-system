<UserControl x:Class="KicsitLibrary.Desktop.Views.ReservationManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100" Background="Transparent">
    
    <UserControl.Resources>
        <!-- Golden focus bounding rings and hover states for Form Elements -->
        <Style TargetType="TextBox" BasedOn="{StaticResource StyledTextBox}">
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#D97706" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#D97706" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="36"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#D97706" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetName="MainGrid"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,15,0,0" To="0,0,0,0" Duration="0:0:0.3">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loader Progress Bar -->
        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" 
                     VerticalAlignment="Top" Margin="0,0,0,10"/>

        <!-- 2-Column Workspace (Left Panel for filters/actions, Right Panel for table grid) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Filters, Form Entries & Operational Actions -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
                <StackPanel>
                    
                    <!-- Search & Filters Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="ILM-O-KUTUB ENTERPRISE NETWORK" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="RESERVATIONS MANAGEMENT" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="Manage active hold requests, priority queues, and expired holds." FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Search Text -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                    <TextBlock Text="Search Title / Member Name:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                </StackPanel>

                                <!-- Status Filter -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,6,10">
                                    <TextBlock Text="Status Filter:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}"/>
                                </StackPanel>

                                <!-- Member Type Filter -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="6,0,0,10">
                                    <TextBlock Text="Member Category:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding MemberTypeOptions}" SelectedItem="{Binding SelectedMemberType}"/>
                                </StackPanel>

                                <!-- From Date -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,6,15">
                                    <TextBlock Text="From Reserved Date:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding FromDate}"/>
                                </StackPanel>

                                <!-- To Date -->
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="6,0,0,15">
                                    <TextBlock Text="To Reserved Date:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding ToDate}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Filter Action Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="🔍 Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Height="36" Padding="15,0"/>
                                <Button Content="🧹 Clear Filters" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Height="36" Padding="15,0"/>
                                <Button Content="➕ New Hold" Command="{Binding CreateCommand}" ToolTip="Create a reservation after member and title eligibility checks." Style="{StaticResource PrimaryButton}" Height="36" Padding="15,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Operations Actions and Details Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="HOLD DISPATCH ACTIONS &amp; AUDIT LOGS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Display details of currently selected reservation -->
                            <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource BgBrush}" CornerRadius="4" Padding="10" Margin="0,0,0,12" 
                                    Visibility="{Binding SelectedReservation, Converter={local:NullToVisibilityConverter}, ConverterParameter=Inverse}">
                                <StackPanel>
                                    <TextBlock Text="SELECTED HOLD DATA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,5"/>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Hold Ref: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedReservation.ReservationNumber}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Member: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedReservation.MemberName}" FontSize="11" Foreground="{StaticResource SecondaryBrush}" Margin="0,2,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Queue Rank: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedReservation.QueuePosition}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OperationalAccentBrush}" Margin="0,2,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Operational Action Reason -->
                            <TextBlock Text="Action Log Reason / Notes (required for cancellation/expiry):" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBox Height="36" Margin="0,0,0,12" Text="{Binding ActionReason, UpdateSourceTrigger=PropertyChanged}" ToolTip="Reason or notes for the action"/>
                            
                            <WrapPanel>
                                <Button Content="📂 View Title Queue" Command="{Binding OpenQueueCommand}" Style="{StaticResource SecondaryButton}" Height="36" Margin="0,0,6,6" Padding="12,0"/>
                                <Button Content="🔔 Mark Available" Command="{Binding MarkAvailableCommand}" Style="{StaticResource PrimaryButton}" Height="36" Margin="0,0,6,6" Padding="12,0"/>
                                <Button Content="✅ Fulfill Hold" Command="{Binding FulfillCommand}" Style="{StaticResource SuccessButton}" Height="36" Margin="0,0,6,6" Padding="12,0"/>
                                <Button Content="❌ Cancel Hold" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" Height="36" Margin="0,0,6,6" Padding="12,0"/>
                                <Button Content="⏳ Expire Hold" Command="{Binding ExpireCommand}" Style="{StaticResource DangerButton}" Height="36" Margin="0,0,6,6" Padding="12,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Status Console Log Card -->
                    <Border Style="{StaticResource CardStyle}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#F1F5F9"
                            Visibility="{Binding StatusMessage, Converter={local:StringVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="SYSTEM RESPONSE OUTFLOW" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{StaticResource SecondaryBrush}" FontSize="12" FontWeight="SemiBold" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT PANEL: DataGrid Ledger (Analytical Tracking Column) -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="RESERVATIONS RECORD LEDGER" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Reservations}" SelectedItem="{Binding SelectedReservation}"
                              AutoGenerateColumns="False" IsReadOnly="True" RowHeight="38" HeadersVisibility="Column"
                              Background="Transparent" RowBackground="White" AlternatingRowBackground="#F8FAFC"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No." Binding="{Binding ReservationNumber}" Width="100" FontWeight="SemiBold"/>
                            <DataGridTemplateColumn Header="Barcode" Width="145">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding ReservationNumber, Converter={local:BarcodeConverter}}" Height="25" Stretch="Uniform" Margin="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Book Title" Binding="{Binding BookTitle}" Width="*"/>
                            <DataGridTextColumn Header="Member" Binding="{Binding MemberName}" Width="130"/>
                            <DataGridTextColumn Header="Queue" Binding="{Binding QueuePosition}" Width="65" FontWeight="Bold" Foreground="{StaticResource OperationalAccentBrush}"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            <DataGridTextColumn Header="Expires" Binding="{Binding ExpiryDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="95" Foreground="{StaticResource WarningBrush}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
