<UserControl x:Class="KicsitLibrary.Desktop.Views.SettingsManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             Background="Transparent">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.4"
                                     DecelerationRatio="0.8"/>
                    <ThicknessAnimation Storyboard.TargetName="MainGrid"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,15,0,0" To="0,0,0,0" Duration="0:0:0.4"
                                        DecelerationRatio="0.8"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="0"
                Height="4"
                IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}"
                     Margin="0,0,0,10"/>

        <!-- Search and Actions -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                        <Button Content="Export Snapshot"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Export masked settings snapshot as JSON"
                                Command="{Binding ExportSnapshotCommand}"
                                IsEnabled="{Binding CanExport}"
                                Margin="0,0,8,0"/>
                        <Button Content="Refresh"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Reload settings from database"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SYSTEM SETTINGS"
                                FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock FontSize="11"
                                Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Manage application settings and configuration"/>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Search:"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"/>
                    <Button DockPanel.Dock="Right"
                            Content="Clear"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="Clear search and filters"
                            Command="{Binding ClearFiltersCommand}"
                            Margin="10,0,0,0"/>
                    <TextBox Style="{StaticResource StyledTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search by key, name, or description"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Settings Grid with Category Selection -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Categories List -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="CATEGORIES"
                            FontWeight="Bold"
                            FontSize="11"
                               Foreground="{StaticResource PrimaryBrush}"
                            Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding Categories}"
                             SelectedValuePath="Name"
                             SelectedValue="{Binding SelectedCategory, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CategoryListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                        Margin="8,4,8,4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                    Width="3"
                    HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- Settings Grid -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="SETTINGS"
                                FontWeight="Bold"
                                FontSize="11"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock DockPanel.Dock="Right"
                                FontSize="10"
                                Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="{Binding VisibleSettings.Count, Mode=OneWay}"/>
                            <Run Text=" setting(s)"/>
                        </TextBlock>
                    </DockPanel>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal"
                             Margin="0,0,0,12">
                        <Button Style="{StaticResource PrimaryButton}"
                                ToolTip="Edit selected setting"
                                Command="{Binding EditSelectedCommand}"
                                IsEnabled="{Binding CanEditSettings}"
                                Margin="0,0,8,0" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏️" Margin="0,0,6,0"/>
                                <TextBlock Text="Edit" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource WarningButton}"
                                ToolTip="Reset selected setting to default value"
                                Command="{Binding ResetSelectedCommand}"
                                IsEnabled="{Binding CanEditSettings}"
                                Margin="0,0,8,0" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️" Margin="0,0,6,0" Foreground="White"/>
                                <TextBlock Text="Reset to Default" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                ToolTip="View detailed information about selected setting"
                                Command="{Binding ViewDetailsCommand}"
                                Margin="0,0,6,0" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" Margin="0,0,6,0"/>
                                <TextBlock Text="Details" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Settings DataGrid -->
                    <DataGrid ItemsSource="{Binding VisibleSettings}"
                              SelectedItem="{Binding SelectedSetting}"
                              CanUserAddRows="False"
                            CanUserDeleteRows="False"
                              CanUserResizeColumns="True"
                              AutoGenerateColumns="False"
                              Style="{StaticResource StyledDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Key"
                                    Binding="{Binding Key}"
                                    Width="150"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="Value"
                                    Binding="{Binding MaskedValue}"
                                    Width="150"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}"
                                    Width="120"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="Data Type"
                                    Binding="{Binding DataType}"
                                    Width="80"
                                    IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Sensitive"
                                    Binding="{Binding IsSensitive}"
                                    Width="70"
                                    IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Restart"
                                    Binding="{Binding RequiresRestart}"
                                    Width="70"
                                    IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Message -->
        <Border Grid.Row="3"
                Background="{StaticResource BgBrush}"
                Margin="0,10,0,0"
                Visibility="{Binding StatusMessage, Converter={local:StringVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}"
                    Margin="12"
                    Foreground="{StaticResource TextMutedBrush}"
                       FontSize="10"
                    TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
