<Window x:Class="KicsitLibrary.Desktop.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop.Views"
        mc:Ignorable="d"
        Title="Forgot Password - Ilm-o-Kutub System" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}"
        WindowStyle="ToolWindow">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Reset Password" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="1" Text="Enter your username, email, or phone. If an account is found, reset instructions will be sent." 
                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,15"/>
        
        <StackPanel Grid.Row="2">
            <TextBlock Text="Username / Email / Phone" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsCodeSent, Converter={StaticResource InvertedBooleanConverter}}" Style="{StaticResource StyledTextBox}" Height="35" ToolTip="Enter username or email"/>
            
            <StackPanel Visibility="{Binding IsCodeSent, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,15,0,0">
                <TextBlock Text="Reset Code" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox Text="{Binding ResetCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource StyledTextBox}" Height="35" ToolTip="Enter 6-digit code"/>

                <TextBlock Text="New Password" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,6"/>
                <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource StyledPasswordBox}" Height="35" ToolTip="Enter new password" PasswordChanged="NewPasswordBox_PasswordChanged"/>

                <TextBlock Text="Confirm Password" Foreground="{StaticResource TextDarkBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource StyledPasswordBox}" Height="35" ToolTip="Confirm new password" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
            </StackPanel>

            <TextBlock Text="{Binding Message}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" Margin="0,15,0,0"
                       Visibility="{Binding Message, Converter={StaticResource StringVisibilityConverter}}"/>
        </StackPanel>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Send Reset Link" Style="{StaticResource PrimaryButton}" Width="130" Command="{Binding RequestResetCommand}" Visibility="{Binding IsCodeSent, Converter={StaticResource InvertedBooleanConverter}, ConverterParameter=Hidden}"/>
            <Button Content="Verify and Reset" Style="{StaticResource PrimaryButton}" Width="130" Command="{Binding ResetPasswordCommand}" Visibility="{Binding IsCodeSent, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Hidden}"/>
        </StackPanel>
    </Grid>
</Window>
