<UserControl x:Class="KicsitLibrary.Desktop.Views.DocumentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Documents" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                <WrapPanel>
                    <TextBox Width="220" Margin="0,0,8,8" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search title, type, filename, uploader, or description."/>
                    <ComboBox Width="165" Margin="0,0,8,8" ItemsSource="{Binding DocumentTypeOptions}"
                              SelectedItem="{Binding SelectedDocumentType}"/>
                    <ComboBox Width="110" Margin="0,0,8,8" ItemsSource="{Binding ActiveStatusOptions}"
                              SelectedItem="{Binding SelectedActiveStatus}"/>
                    <TextBox Width="135" Margin="0,0,8,8" Text="{Binding UploadedBy, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter by uploader name."/>
                    <DatePicker Width="130" Margin="0,0,8,8" SelectedDate="{Binding FromDate}"/>
                    <DatePicker Width="130" Margin="0,0,8,8" SelectedDate="{Binding ToDate}"/>
                    <TextBox Width="140" Margin="0,0,8,8" Text="{Binding RelatedEntityType, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Optional related entity type such as AuditRecord or InventoryItem."/>
                    <TextBox Width="90" Margin="0,0,8,8" Text="{Binding RelatedEntityIdText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Optional related entity id."/>
                    <CheckBox Content="Expired only" IsChecked="{Binding ExpiredOnly}" Margin="0,0,12,8"
                              VerticalAlignment="Center"/>
                    <CheckBox Content="Missing file only" IsChecked="{Binding MissingFileOnly}" Margin="0,0,12,8"
                              VerticalAlignment="Center"/>
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}"
                            ToolTip="Reload documents using the selected filters." Margin="0,0,8,8"/>
                    <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,8"/>
                    <Button Content="Upload Document" Command="{Binding UploadDocumentCommand}" Style="{StaticResource PrimaryButton}"
                            ToolTip="Validate and upload a local administrative document." Margin="0,0,8,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title" Binding="{Binding DocumentTitle}" Width="*"/>
                    <DataGridTextColumn Header="Document Type" Binding="{Binding DocumentType}" Width="145"/>
                    <DataGridTextColumn Header="Version" Binding="{Binding VersionNumber}" Width="75"/>
                    <DataGridTextColumn Header="Original File Name" Binding="{Binding OriginalFileName}" Width="170"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding FileSizeBytes, StringFormat={}{0:N0}}" Width="90"/>
                    <DataGridTextColumn Header="Uploaded By" Binding="{Binding UploadedBy}" Width="135"/>
                    <DataGridTextColumn Header="Upload Date" Binding="{Binding UploadDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                    <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding ActiveStatus}" Width="100"/>
                    <DataGridTextColumn Header="Related Entity" Binding="{Binding RelatedEntityType}" Width="130"/>
                    <DataGridTextColumn Header="Entity Id" Binding="{Binding RelatedEntityId}" Width="75"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <StackPanel>
                <WrapPanel>
                    <Button Content="View Details" Command="{Binding ViewDetailsCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="Open metadata and file status for the selected document." Margin="0,0,8,8"/>
                    <Button Content="Open Document" Command="{Binding OpenDocumentCommand}" Style="{StaticResource PrimaryButton}"
                            ToolTip="Open the selected document after authorization and file checks." Margin="0,0,8,8"/>
                    <Button Content="Copy To" Command="{Binding CopyToCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="Copy the selected stored document to another folder." Margin="0,0,8,8"/>
                    <TextBox Width="260" Margin="0,0,8,8" Text="{Binding DeleteReason, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Required reason for soft delete."/>
                    <Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}" Style="{StaticResource DangerButton}"
                            ToolTip="Soft-delete the selected document record without deleting the physical file." Margin="0,0,8,8"/>
                    <Button Content="Restore Selected" Command="{Binding RestoreSelectedCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="Restore a soft-deleted document if its stored file still exists." Margin="0,0,8,8"/>
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{StaticResource SecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
