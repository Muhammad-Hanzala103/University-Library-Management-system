<Window x:Class="KicsitLibrary.Desktop.Views.InventoryAdjustmentWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Adjust Inventory Quantity" Width="430" Height="380" WindowStartupLocation="CenterOwner"><Border Style="{StaticResource CardStyle}" Margin="15"><StackPanel><TextBlock Text="{Binding ItemName}" FontSize="20" FontWeight="Bold"/><TextBlock Text="Total quantity"/><TextBox Text="{Binding Quantity}"/><TextBlock Text="Available quantity"/><TextBox Text="{Binding AvailableQuantity}"/><TextBlock Text="Damaged quantity"/><TextBox Text="{Binding DamagedQuantity}"/><TextBlock Text="Reason"/><TextBox Text="{Binding Reason}"/><TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8"/><WrapPanel><Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/><Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"/></WrapPanel></StackPanel></Border></Window>
