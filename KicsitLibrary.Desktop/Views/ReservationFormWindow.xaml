<Window x:Class="KicsitLibrary.Desktop.Views.ReservationFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Reservation" Height="650" Width="760"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Member and Title Search" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                <WrapPanel VerticalAlignment="Bottom">
                    <StackPanel Width="140" Margin="0,0,8,8">
                        <TextBlock Text="Member Type" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding MemberTypes}" SelectedItem="{Binding SelectedMemberType}"/>
                    </StackPanel>
                    
                    <StackPanel Width="220" Margin="0,0,8,8">
                        <TextBlock Text="Member Search" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                        <Grid>
                            <TextBox x:Name="MemberSearchBox" Style="{StaticResource StyledTextBox}" 
                                     Text="{Binding MemberSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter member registration/personnel number, name, email, or CNIC. Matches are shown on search."/>
                            <TextBlock Text="Registration Number, Name..." Foreground="{StaticResource TextMutedBrush}" 
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="11,2,0,0" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=MemberSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                    
                    <StackPanel Width="220" Margin="0,0,8,8">
                        <TextBlock Text="Title Search" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                        <Grid>
                            <TextBox x:Name="BookSearchBox" Style="{StaticResource StyledTextBox}" 
                                     Text="{Binding BookSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter title, accession number, author, ISBN, journal, magazine, or newspaper."/>
                            <TextBlock Text="Title, Accession, Author..." Foreground="{StaticResource TextMutedBrush}" 
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="11,2,0,0" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=BookSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                    
                    <Button Content="Search" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButton}" Height="34" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Student" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedStudent}"
                              DisplayMemberPath="Name" Margin="0,6,0,12"/>
                    <TextBlock Text="Faculty / Staff" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding FacultyStaff}" SelectedItem="{Binding SelectedFacultyStaff}"
                              DisplayMemberPath="Name" Margin="0,6,0,12"/>
                    <TextBlock Text="Remarks" FontWeight="Bold"/>
                    <TextBox Text="{Binding Remarks}" AcceptsReturn="True" Height="75" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Book Title" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding Books}" SelectedItem="{Binding SelectedBook}"
                              DisplayMemberPath="Title" Margin="0,6,0,12"/>
                    <Button Content="Check Eligibility" Command="{Binding CheckEligibilityCommand}"
                            ToolTip="Validate the selected member and title before creating a reservation."
                            Style="{StaticResource SecondaryButton}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding Eligibility.Message}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Eligibility.ActiveReservationCount, StringFormat=Active reservations: {0}}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding Eligibility.AvailableCopyCount, StringFormat=Available copies: {0}}"/>
                    <TextBlock Text="{Binding Eligibility.PendingFineAmount, StringFormat=Pending fines: Rs. {0:N2}}"/>
                </StackPanel>
            </Border>
        </Grid>
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Create" Command="{Binding CreateCommand}" ToolTip="Save the eligible reservation and assign its queue position." Style="{StaticResource PrimaryButton}" Margin="8,0"/>
                    <Button Content="Close" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
