<Window x:Class="KicsitLibrary.Desktop.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        xmlns:helpers="clr-namespace:KicsitLibrary.Desktop.Helpers"
        Title="Change Password - Ilm-o-Kutub System"
        Width="440"
        Height="440"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2E3E56" Offset="0.0"/>
                    <GradientStop Color="#141D2A" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="Change Password"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Modify security credentials for the current account"
                           FontSize="10"
                           Foreground="#93C5FD"
                           Opacity="0.8"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Current Password -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Current Password"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               Foreground="{StaticResource TextDarkBrush}"/>
                    <PasswordBox x:Name="CurrentPasswordInput"
                                 Padding="8"
                                 Height="36"
                                 BorderThickness="1"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 helpers:PasswordHelper.BindPassword="True"
                                 helpers:PasswordHelper.BoundPassword="{Binding CurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- New Password -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="New Password"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               Foreground="{StaticResource TextDarkBrush}"/>
                    <PasswordBox x:Name="NewPasswordInput"
                                 Padding="8"
                                 Height="36"
                                 BorderThickness="1"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 helpers:PasswordHelper.BindPassword="True"
                                 helpers:PasswordHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Confirm Password -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Confirm New Password"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               Foreground="{StaticResource TextDarkBrush}"/>
                    <PasswordBox x:Name="ConfirmPasswordInput"
                                 Padding="8"
                                 Height="36"
                                 BorderThickness="1"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 helpers:PasswordHelper.BindPassword="True"
                                 helpers:PasswordHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Error Message -->
                <Border Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"
                        Background="#FEE2E2"
                        BorderThickness="1"
                        BorderBrush="#FCA5A5"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,0,0,10">
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#B91C1C"
                               FontWeight="SemiBold"/>
                </Border>

                <!-- Success Message -->
                <Border Visibility="{Binding SuccessMessage, Converter={local:StringVisibilityConverter}}"
                        Background="#DCFCE7"
                        BorderThickness="1"
                        BorderBrush="#86EFAC"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,0,0,10">
                    <TextBlock Text="{Binding SuccessMessage}"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#15803D"
                               FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Padding="20,16" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}"
                        Width="90"
                        Margin="8,0,0,0"
                        IsEnabled="{Binding IsBusy, Converter={local:InvertedBooleanConverter}}"/>
                <Button DockPanel.Dock="Right"
                        Content="Save Changes"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ChangePasswordCommand}"
                        Width="120"
                        IsEnabled="{Binding IsBusy, Converter={local:InvertedBooleanConverter}}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
