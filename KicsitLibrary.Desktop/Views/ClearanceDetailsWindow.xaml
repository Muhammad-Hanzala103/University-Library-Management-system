<Window x:Class="KicsitLibrary.Desktop.Views.ClearanceDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="650" Width="950"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding CheckResult.MemberName}" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="{Binding CheckResult.Message}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        <GroupBox Grid.Row="1" Header="Borrowing History" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding BorrowingHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Accession" Binding="{Binding AccessionNumber}" Width="110"/>
                    <DataGridTextColumn Header="Book" Binding="{Binding BookCopy.BookMaster.Title}" Width="*"/>
                    <DataGridTextColumn Header="Issue Date" Binding="{Binding IssueDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                    <DataGridTextColumn Header="Due Date" Binding="{Binding ExpectedReturnDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                    <DataGridTextColumn Header="Receive Date" Binding="{Binding ReceiveRecord.ReceiveDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>
                    <DataGridTextColumn Header="Fine" Binding="{Binding Fine.RemainingAmount, StringFormat={}{0:N2}}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox Grid.Row="2" Header="Clearance History">
            <DataGrid ItemsSource="{Binding ClearanceHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="160"/>
                    <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*"/>
                    <DataGridTextColumn Header="Performed By" Binding="{Binding PerformedBy}" Width="140"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding PerformedAt, StringFormat={}{0:dd-MMM-yyyy HH:mm}}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                   TextWrapping="Wrap" Margin="0,8,0,0"/>
    </Grid>
</Window>
