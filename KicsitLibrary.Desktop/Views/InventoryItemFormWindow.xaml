<Window x:Class="KicsitLibrary.Desktop.Views.InventoryItemFormWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{Binding Title}" Width="520" Height="600" WindowStartupLocation="CenterOwner"><ScrollViewer><Border Style="{StaticResource CardStyle}" Margin="15"><StackPanel><TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold"/><TextBlock Text="Item name"/><TextBox Text="{Binding ItemName}"/><TextBlock Text="Item type"/><ComboBox ItemsSource="{Binding ItemTypes}" SelectedItem="{Binding ItemType}"/><TextBlock Text="Total / Available / Damaged"/><WrapPanel><TextBox Width="100" Text="{Binding Quantity}"/><TextBox Width="100" Text="{Binding AvailableQuantity}" Margin="8,0"/><TextBox Width="100" Text="{Binding DamagedQuantity}"/></WrapPanel><TextBlock Text="Location"/><TextBox Text="{Binding Location}"/><TextBlock Text="Condition"/><TextBox Text="{Binding Condition}"/><TextBlock Text="Purchase date"/><DatePicker SelectedDate="{Binding PurchaseDate}"/><TextBlock Text="Purchase price"/><TextBox Text="{Binding PurchasePrice}"/><TextBlock Text="Supplier"/><TextBox Text="{Binding Supplier}"/><TextBlock Text="Remarks"/><TextBox Text="{Binding Remarks}" Height="60" AcceptsReturn="True"/><TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8"/><WrapPanel><Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/><Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"/></WrapPanel></StackPanel></Border></ScrollViewer></Window>
