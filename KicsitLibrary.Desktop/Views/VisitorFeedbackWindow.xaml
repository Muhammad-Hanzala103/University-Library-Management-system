<Window x:Class="KicsitLibrary.Desktop.Views.VisitorFeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KicsitLibrary.Desktop"
        mc:Ignorable="d"
        x:Name="feedbackWindow"
        Title="{Binding WindowTitle}" Height="550" Width="520"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}"
        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,15" Padding="0,0,0,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Register suggestions, inquiries, complaints or appreciation from library visitors." FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
        </Border>

        <!-- Form Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <!-- Visitor Name -->
                <TextBlock Text="Visitor Name *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding VisitorName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <!-- Contact Fields Grid -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="CNIC" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Cnic, UpdateSourceTrigger=PropertyChanged}" ToolTip="Format: 12345-1234567-1"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="Phone Number" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- Email -->
                <TextBlock Text="Email Address" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <!-- Purpose of Visit -->
                <TextBlock Text="Visit Purpose *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding VisitPurpose, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <!-- Feedback Type -->
                <TextBlock Text="Feedback Type" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding FeedbackTypes}" SelectedItem="{Binding FeedbackType}"/>

                <!-- Feedback Text -->
                <TextBlock Text="Feedback / Suggestion Text *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding FeedbackText, UpdateSourceTrigger=PropertyChanged}" Height="80"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

                <!-- Review Fields (Visible in Edit Mode) -->
                <StackPanel Visibility="{Binding IsEditingMode, Converter={local:BooleanToVisibilityConverter}}">
                    <TextBlock Text="FEEDBACK STATUS &amp; REMARKS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,10"/>
                    
                    <TextBlock Text="Status" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Height="36" Margin="0,0,0,12" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>

                    <TextBlock Text="Reviewed Remarks" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding ReviewedRemarks, UpdateSourceTrigger=PropertyChanged}" Height="60"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="0,12,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" CommandParameter="{Binding ElementName=feedbackWindow}" Width="90" Margin="0,0,10,0"/>
                    <Button Content="Save Feedback" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" CommandParameter="{Binding ElementName=feedbackWindow}" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
