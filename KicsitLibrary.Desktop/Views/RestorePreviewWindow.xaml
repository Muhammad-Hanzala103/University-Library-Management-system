<Window x:Class="KicsitLibrary.Desktop.Views.RestorePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verified SQLite Restore"
        Width="760"
        Height="720"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer>
        <Border Style="{StaticResource CardStyle}" Margin="15">
            <StackPanel>
                <TextBlock Text="Verified Local SQLite Restore" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Restore is staged and applied only during the next application startup."
                           Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold"
                           Margin="0,6,0,12" TextWrapping="Wrap"/>

                <TextBlock Text="Backup file" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Preview.BackupFilePath}" IsReadOnly="True" TextWrapping="Wrap"/>
                <WrapPanel Margin="0,8,0,0">
                    <TextBlock Text="{Binding Preview.BackupSizeBytes, StringFormat=Size: {0:N0} bytes}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Preview.IntegrityCheckPassed, StringFormat=Integrity passed: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Preview.DetectedTablesCount, StringFormat=Tables: {0}}"/>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <TextBlock Text="{Binding Preview.DetectedUserCount, StringFormat=Users: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Preview.DetectedBookCopyCount, StringFormat=Book copies: {0}}" Margin="0,0,18,0"/>
                    <TextBlock Text="{Binding Preview.DetectedIssueRecordCount, StringFormat=Issues: {0}}"/>
                </WrapPanel>
                <TextBlock Text="SHA-256 checksum" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBox Text="{Binding Preview.ChecksumSha256}" IsReadOnly="True" TextWrapping="Wrap"/>

                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="Reason (required)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Type RESTORE exactly" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding ConfirmationText, UpdateSourceTrigger=PropertyChanged}"/>
                    <CheckBox Content="Create mandatory safety backup"
                              IsChecked="{Binding CreateSafetyBackup}" Margin="0,8,0,0"/>
                    <CheckBox Content="Verify backup before restore"
                              IsChecked="{Binding VerifyBeforeRestore}"/>
                    <CheckBox Content="Verify restored database after startup replacement"
                              IsChecked="{Binding VerifyAfterRestore}"/>
                    <TextBlock Text="A verified safety backup is always required. The active database is never replaced while the application is running."
                               Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <WrapPanel Margin="0,14,0,0">
                    <Button Content="Validate Backup" Command="{Binding ValidateCommand}"
                            ToolTip="Re-run integrity and schema validation on this backup."
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Stage Restore" Command="{Binding RestoreCommand}"
                            ToolTip="Create a safety backup and stage this verified restore for restart."
                            Style="{StaticResource PrimaryButton}"/>
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
