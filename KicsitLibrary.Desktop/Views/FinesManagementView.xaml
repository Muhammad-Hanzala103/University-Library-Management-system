<UserControl x:Class="KicsitLibrary.Desktop.Views.FinesManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KicsitLibrary.Desktop"
             xmlns:coreEnums="clr-namespace:KicsitLibrary.Core.Enums;assembly=KicsitLibrary.Core"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000" Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Loader Progress Bar -->
        <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={local:BooleanToVisibilityConverter}}" 
                     VerticalAlignment="Top" Margin="0,0,0,10"/>

        <!-- Top Search Bar Panel -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Search Fines (Member Name, Ref No, CNIC, Roll No)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                
                <Button Grid.Column="1" Content="🔍 Search Fines" Style="{StaticResource PrimaryButton}" Command="{Binding SearchFinesCommand}" VerticalAlignment="Bottom" Height="36" Width="130"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Fines List Card -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="OUTSTANDING FINES REGISTRY" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding UnpaidFines}" SelectedItem="{Binding SelectedFine}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <!-- Fine Ref Number -->
                            <DataGridTextColumn Header="Fine ID" Binding="{Binding FineRecordNumber}" Width="100"/>
                            
                            <!-- Dynamic Member Name Column -->
                            <DataGridTemplateColumn Header="Member" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MemberType}" Value="{x:Static coreEnums:MemberType.Student}">
                                                                <Setter Property="Text" Value="{Binding Student.Name}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MemberType}" Value="{x:Static coreEnums:MemberType.FacultyStaff}">
                                                                <Setter Property="Text" Value="{Binding FacultyStaff.Name}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock FontSize="10" Foreground="{StaticResource TextMutedBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MemberType}" Value="{x:Static coreEnums:MemberType.Student}">
                                                                <Setter Property="Text" Value="{Binding Student.RegistrationNumber}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MemberType}" Value="{x:Static coreEnums:MemberType.FacultyStaff}">
                                                                <Setter Property="Text" Value="{Binding FacultyStaff.PersonnelNumber}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Accession Number -->
                            <DataGridTextColumn Header="Accession" Binding="{Binding AccessionNumber}" Width="100"/>

                            <!-- Fine Type / Reason -->
                            <DataGridTextColumn Header="Type" Binding="{Binding FineType}" Width="90"/>

                            <!-- Created Date (Fine Date) -->
                            <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat='dd-MMM-yyyy'}" Width="100"/>

                            <!-- Fine Amount Details -->
                            <DataGridTextColumn Header="Total (Rs)" Binding="{Binding FineAmount, StringFormat='{}{0:N0}'}" Width="80"/>
                            <DataGridTextColumn Header="Waived" Binding="{Binding WaivedAmount, StringFormat='{}{0:N0}'}" Width="80"/>
                            <DataGridTextColumn Header="Remaining (Rs)" Binding="{Binding RemainingAmount, StringFormat='{}{0:N0}'}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- RIGHT: Actions Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Fallback State -->
                    <Border Style="{StaticResource CardStyle}" VerticalAlignment="Stretch"
                            Visibility="{Binding SelectedFine, Converter={local:NullToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                            <TextBlock Text="💳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Select Fine Record" Style="{StaticResource TitleTextStyle}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Choose any outstanding fine record from the table on the left to collect cash payments or apply waivers." 
                                       Style="{StaticResource SubtitleTextStyle}" HorizontalAlignment="Center" TextAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Active Fine Selected Panel -->
                    <StackPanel Visibility="{Binding SelectedFine, Converter={local:NullToVisibilityConverter}, ConverterParameter=Inverse}">
                        
                        <!-- Selected Summary Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5,1,1,1">
                            <StackPanel>
                                <TextBlock Text="SELECTED FINE DETAILS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedFine.FineRecordNumber, StringFormat='Reference: {0}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                
                                <Grid Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="Fine Reason" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFine.FineType}" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Days Overdue" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFine.DaysOverdue, StringFormat='{}{0} days'}" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="Accession" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFine.AccessionNumber}" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="Outstanding" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding SelectedFine.RemainingAmount, StringFormat='Rs. {0:N0}'}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Collect Cash Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="COLLECT CASH PAYMENT" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="Amount to Pay (Rs.) *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <TextBlock Text="Payment Remarks" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding PaymentRemarks, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                                <Button Content="💵 Collect Payment" Style="{StaticResource PrimaryButton}" Command="{Binding CollectPaymentCommand}" Height="36"/>
                            </StackPanel>
                        </Border>

                        <!-- Waive / Discount Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="APPLY FINE WAIVER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="Amount to Waive (Rs.) *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding WaiveAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <TextBlock Text="Waiver / Discount Reason *" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource StyledTextBox}" Text="{Binding WaiverReason, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                                <Button Content="✂️ Waive / Discount Fine" Style="{StaticResource PrimaryButton}" Background="{StaticResource DangerBrush}" Command="{Binding WaiveFineCommand}" Height="36"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Status / Error Bar -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,15,0,0" Padding="8" FontWeight="SemiBold" TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={local:StringVisibilityConverter}}"/>
    </Grid>
</UserControl>
