<Window x:Class="KicsitLibrary.Desktop.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Title="Ilm o Kutub System"
        Height="420" Width="720">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContainer"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.8"
                                     DecelerationRatio="0.8"/>
                    <ThicknessAnimation Storyboard.TargetName="MainContainer"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.8"
                                        DecelerationRatio="0.8"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid>
        <!-- Background Shadow and Main Border -->
        <Border CornerRadius="8" Background="#1F2937" BorderThickness="1.5" BorderBrush="#374151">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.55" ShadowDepth="3"/>
            </Border.Effect>
            <Grid x:Name="MainContainer" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top Accents / Headers -->
                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Top Accent Line -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="60" Height="4" Fill="#2563EB" Margin="0,0,8,0" RadiusX="2" RadiusY="2"/>
                            <Rectangle Width="30" Height="4" Fill="#0F766E" RadiusX="2" RadiusY="2"/>
                        </StackPanel>
                        <!-- Version -->
                        <TextBlock x:Name="VersionText" Grid.Column="1" Text="v1.0.0" Foreground="#6B7280" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Main Branding Section -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,20">
                    <TextBlock Text="Ilm o Kutub System" Foreground="#FFFFFF" FontSize="42" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="4" Color="#000000" Opacity="0.3" ShadowDepth="1.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Advanced University Library Management System" Foreground="#0F766E" FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Status and Progress Area -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="10,0,10,24">
                    <TextBlock x:Name="StatusText" Text="Starting application..." Foreground="#D1D5DB" FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                    <ProgressBar x:Name="ProgressIndicator" Height="6" IsIndeterminate="True" Background="#374151" BorderThickness="0">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2563EB" Offset="0.0"/>
                                <GradientStop Color="#0F766E" Offset="1.0"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                </StackPanel>

                <!-- Footer Team info -->
                <Grid Grid.Row="3" Margin="10,0,10,0">
                    <TextBlock Text="Developed for Advanced Visual Programming Lab" Foreground="#6B7280" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
